flac3d>fish define add_crack(entries)
   Def>    local contact    = entries(1)
   Def>    local mode       = entries(2)    ; slot2 = failure mode {1=tension, 2=shear}
   Def>    local frac_pos   = contact.pos(contact)
   Def>    local norm       = contact.normal(contact)
   Def>    local dfn_label  = 'crack'
   Def>    local bp1 = contact.end1(contact)
   Def>    local bp2 = contact.end2(contact)
   Def>    local frac_size = math.min(ball.radius(bp1), ball.radius(bp2))
   Def>    local arg = array.create(5)
   Def>    arg(1) = 'disk'
   Def>    arg(2) = frac_pos
   Def>    arg(3) = frac_size
   Def>    arg(4) = math.dip.from.normal(norm)/math.degrad
   Def>    arg(5) = math.ddir.from.normal(norm)/math.degrad
   Def>    if arg(5) < 0.0
   Def>        arg(5) = 360.0+arg(5)
   Def>    end_if
   Def>    global crack_num
   Def>    crack_num = crack_num + 1
   Def>    if mode = 1 then
   Def>        dfn_label = dfn_label + '_tension'
   Def>    else if mode = 2 then
   Def>        dfn_label = dfn_label + '_shear'
   Def>    endif
   Def>    global dfn = dfn.find(dfn_label)
   Def>    if dfn = null then
   Def>        dfn = dfn.create(dfn_label)
   Def>    endif
   Def>    local fnew = fracture.create(dfn,arg)
   Def>    fracture.prop(fnew,'age')  = mech.time.total
   Def>    fracture.extra(fnew,1) = bp1
   Def>    fracture.extra(fnew,2) = bp2
   Def>    crack_accum += 1
   Def>end
