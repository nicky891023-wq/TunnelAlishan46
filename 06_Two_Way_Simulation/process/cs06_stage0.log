flac3d>; ---- drive-file reader (x y z dx dy dz, 1 header line) ----
flac3d>fish define read_drive(fname)
   Def>    local arr = array.create(1)
   Def>    local st = file.open(fname,0,1)
   Def>    ndata = 0
   Def>    st = file.read(arr,1)
   Def>    st = file.read(arr,1)
   Def>    loop while st = 0
   Def>        ndata = ndata + 1
   Def>        st = file.read(arr,1)
   Def>    end_loop
   Def>    st = file.close
   Def>    xdat  = array.create(ndata)
   Def>    ydat  = array.create(ndata)
   Def>    zdat  = array.create(ndata)
   Def>    uxdat = array.create(ndata)
   Def>    uydat = array.create(ndata)
   Def>    uzdat = array.create(ndata)
   Def>    st = file.open(fname,0,1)
   Def>    st = file.read(arr,1)
   Def>    local i = 0
   Def>    st = file.read(arr,1)
   Def>    loop while st = 0
   Def>        i = i + 1
   Def>        local ln = arr(1)
   Def>        xdat(i)  = string.token(ln,1)
   Def>        ydat(i)  = string.token(ln,2)
   Def>        zdat(i)  = string.token(ln,3)
   Def>        uxdat(i) = string.token(ln,4)
   Def>        uydat(i) = string.token(ln,5)
   Def>        uzdat(i) = string.token(ln,6)
   Def>        st = file.read(arr,1)
   Def>    end_loop
   Def>    st = file.close
   Def>    io.out('   CS-read '+fname+' ndata='+string(ndata))
   Def>end
flac3d>
flac3d>; ---- store per-gp IDW targets in gp.extra(1..3) (radius 6 m, 1/d^2, nearest fallback) ----
flac3d>fish define set_targets(radius)
   Def>    loop foreach local g gp.list
   Def>        if gp.group(g,'drive') = 'driven' then
   Def>            local p = gp.pos(g)
   Def>            local x = comp.x(p)
   Def>            local y = comp.y(p)
   Def>            local z = comp.z(p)
   Def>            local sw = 0.0
   Def>            local sux = 0.0
   Def>            local suy = 0.0
   Def>            local suz = 0.0
   Def>            local dmin = 1e30
   Def>            local i = 1
   Def>            loop while i <= ndata
   Def>                local dx = x - xdat(i)
   Def>                local dy = y - ydat(i)
   Def>                local dz = z - zdat(i)
   Def>                local d2 = dx*dx + dy*dy + dz*dz
   Def>                if d2 <= radius*radius then
   Def>                    local w = 1.0/math.max(d2,1e-10)
   Def>                    sw = sw + w
   Def>                    sux = sux + uxdat(i)*w
   Def>                    suy = suy + uydat(i)*w
   Def>                    suz = suz + uzdat(i)*w
   Def>                end_if
   Def>                if d2 < dmin then
   Def>                    dmin = d2
   Def>                    global inear = i
   Def>                end_if
   Def>                i = i + 1
   Def>            end_loop
   Def>            ; DRIVE_SCALE (Option A, 2026-07-06): reduce imposed deformation to keep the
   Def>            ; discrete lining in the crack-DEVELOPMENT regime (not fragmentation). f=0.25
   Def>            ; calibrated by couple_load_diag (1.2mm->~100 cracks; 2.4mm->shatter). Materials
   Def>            ; unchanged (rock E_eq 2.31, lining D7 ft4). Magnitudes are scaled TREND, pattern
   Def>            ; and stage-to-stage relative behavior preserved.
   Def>            if sw > 0.0 then
   Def>                gp.extra(g,1) = DRIVE_SCALE*sux/sw
   Def>                gp.extra(g,2) = DRIVE_SCALE*suy/sw
   Def>                gp.extra(g,3) = DRIVE_SCALE*suz/sw
   Def>            else
   Def>                gp.extra(g,1) = DRIVE_SCALE*uxdat(inear)
   Def>                gp.extra(g,2) = DRIVE_SCALE*uydat(inear)
   Def>                gp.extra(g,3) = DRIVE_SCALE*uzdat(inear)
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>end
flac3d>
flac3d>; ---- one ramp substep: vel = remaining_delta / (subs_left * NCYC * dt=1) ----
flac3d>fish define set_sub_vel(subs_left)
   Def>    loop foreach local g gp.list
   Def>        if gp.group(g,'drive') = 'driven' then
   Def>            local d = gp.disp(g)
   Def>            local den = float(subs_left)*float(NCYC)
   Def>            gp.vel(g) = vector((gp.extra(g,1)-comp.x(d))/den, (gp.extra(g,2)-comp.y(d))/den, (gp.extra(g,3)-comp.z(d))/den)
   Def>        end_if
   Def>    end_loop
   Def>end
