   Def>    ; INNER-WALL (r 1.35-2.0m) radial convergence, split by region (Codex): blue-line load region
   Def>    ;   (ang NOT in 250-320deg = sidewalls+crown) vs fixed-corner band (ang 250-320 = artifact).
   Def>    global cv_blue = 0.0
   Def>    global mx_blue = 0.0
   Def>    global nb_blue = 0
   Def>    global cv_corner = 0.0
   Def>    global mx_corner = 0.0
   Def>    global nb_corner = 0
   Def>    local sblue = 0.0
   Def>    local scorner = 0.0
   Def>    loop foreach local b ball.list
   Def>        local p = ball.pos(b)
   Def>        local yy = comp.y(p)
