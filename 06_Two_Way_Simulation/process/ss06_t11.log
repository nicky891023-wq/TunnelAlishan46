flac3d>; ---- shell stress MONITOR (05 secant cap disarmed: 06 has a single damage source,
flac3d>;      the coupled D->E feedback; the cap remains as observability + abort signal) ----
flac3d>fish define shell_monitor
   Def>    command
   Def>        structure shell recover surface (0,1,0)
   Def>        structure shell recover stress depth-factor 0
   Def>    endcommand
   Def>    global n_wouldcap = 0
   Def>    global sh_maxc = 0.0
   Def>    global sh_maxt = 0.0
   Def>    loop foreach local s struct.list
   Def>        if struct.type(s) = 'shell' then
   Def>            local smn = 1e30
   Def>            local smx = -1e30
   Def>            loop local k (0,3)
   Def>                local sx = struct.shell.stress.prin.x(s,k)
   Def>                local sz = struct.shell.stress.prin.z(s,k)
   Def>                if sx < smn then
   Def>                    smn = sx
   Def>                end_if
   Def>                if sz > smx then
   Def>                    smx = sz
   Def>                end_if
   Def>            end_loop
   Def>            local sc = 0.0
   Def>            if smn < 0.0 then
   Def>                sc = -smn
   Def>            end_if
   Def>            local stn = 0.0
   Def>            if smx > 0.0 then
   Def>                stn = smx
   Def>            end_if
   Def>            if sc > sh_maxc then
   Def>                sh_maxc = sc
   Def>            end_if
   Def>            if stn > sh_maxt then
   Def>                sh_maxt = stn
   Def>            end_if
   Def>            if sc > (1.0+sig_eps)*sig_capC then
   Def>                n_wouldcap = n_wouldcap + 1
   Def>            else if stn > (1.0+sig_eps)*sig_capT then
   Def>                n_wouldcap = n_wouldcap + 1
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>end
