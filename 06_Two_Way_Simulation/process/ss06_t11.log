flac3d>; ---- D->E feedback: read 24x5 cell table 'isec iband E' (1 header line), write
flac3d>;      struct.shell.young once per tick + single struct.force.update (the proven
flac3d>;      05 cap cadence wrote E every 1.25 d; once per 5 d is strictly gentler).
flac3d>;      Cell frame MUST match make_damage_map_v2.py:
flac3d>;      theta = atan2(x-1297, z-1747.5) in deg wrapped to [0,360); isec=int(th/15)+1;
flac3d>;      iband = int((y-860)/10)+1 clamped to [1,5] (out-of-ring y -> guard bands=E0). ----
flac3d>fish define apply_shellE(fname)
   Def>    local arr = array.create(1)
   Def>    local st = file.open(fname,0,1)
   Def>    st = file.read(arr,1)
   Def>    global Ecell = array.create(24,5)
   Def>    st = file.read(arr,1)
   Def>    loop while st = 0
   Def>        local ln = arr(1)
   Def>        local i1 = int(string.token(ln,1))
   Def>        local i2 = int(string.token(ln,2))
   Def>        Ecell(i1,i2) = float(string.token(ln,3))
   Def>        st = file.read(arr,1)
   Def>    end_loop
   Def>    st = file.close
   Def>    global n_ewrite = 0
   Def>    global n_echange = 0
   Def>    loop foreach local s struct.list
   Def>        if struct.type(s) = 'shell' then
   Def>            local p = struct.pos(s)
   Def>            local th = math.atan2(comp.x(p)-1297.0, comp.z(p)-1747.5)/math.degrad
   Def>            if th < 0.0 then
   Def>                th = th + 360.0
