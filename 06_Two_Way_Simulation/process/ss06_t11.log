flac3d>
flac3d>; ---- advance the creep clock by exactly days_add (1.25-day chunks, 05 cadence).
flac3d>;      NO re-aiming here: boundary gp velocities were set once at the stage prologue
flac3d>;      (constant-velocity law); ticks only extend model solve creep time-total. ----
flac3d>fish define crp_tick(stg, days_add)
   Def>    if abort_flag = 1 then
   Def>        io.out('SS06-SKIP tick (abort flag set)')
   Def>    else
   Def>    local nch = math.ceiling(days_add/1.25)
   Def>    local dch = days_add/nch
   Def>    local ich = 0
   Def>    loop while ich < nch
   Def>        ich = ich + 1
   Def>        cum_days = cum_days + dch
   Def>        command
   Def>            model creep timestep fix [crp_dt]
   Def>            model solve creep time-total [cum_days*86400.0]
   Def>        endcommand
   Def>        shell_monitor
   Def>        count_active
   Def>        io.out('SS06-HIST stg='+string(stg)+' day='+string(cum_days)+' vclose='+string(vclose)+' hclose='+string(hclose)+' dmax='+string(dmax_all)+' active='+string(n_active)+' nwould='+string(n_wouldcap)+' maxC='+string(sh_maxc/1e6)+'MPa maxT='+string(sh_maxt/1e6)+'MPa')
   Def>        if dmax_all > 0.20 then
   Def>            abort_flag = 1
   Def>            ich = nch
   Def>            io.out('SS06-ABORT kinematic runaway dmax>0.2m (stg '+string(stg)+')')
   Def>        end_if
   Def>    end_loop
   Def>    end_if
   Def>end
