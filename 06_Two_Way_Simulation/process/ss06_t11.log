flac3d>; --- read stage drive file: header + rows 'x y z dx dy dz' ---
flac3d>fish define read_drive(fname)
   Def>    local arr = array.create(1)
   Def>    local st = file.open(fname,0,1)
   Def>    ndata = 0
   Def>    st = file.read(arr,1)
   Def>    st = file.read(arr,1)
   Def>    loop while st = 0
   Def>        ndata = ndata + 1
   Def>        st = file.read(arr,1)
   Def>    end_loop
   Def>    st = file.close
   Def>    xdat  = array.create(ndata)
   Def>    ydat  = array.create(ndata)
   Def>    zdat  = array.create(ndata)
   Def>    uxdat = array.create(ndata)
   Def>    uydat = array.create(ndata)
   Def>    uzdat = array.create(ndata)
   Def>    st = file.open(fname,0,1)
   Def>    st = file.read(arr,1)
   Def>    local i = 0
   Def>    st = file.read(arr,1)
   Def>    loop while st = 0
   Def>        i = i + 1
   Def>        local ln = arr(1)
   Def>        xdat(i)  = string.token(ln,1)
   Def>        ydat(i)  = string.token(ln,2)
   Def>        zdat(i)  = string.token(ln,3)
   Def>        uxdat(i) = string.token(ln,4)
   Def>        uydat(i) = string.token(ln,5)
   Def>        uzdat(i) = string.token(ln,6)
   Def>        st = file.read(arr,1)
   Def>    end_loop
   Def>    st = file.close
   Def>    io.out('   SSv2-read '+fname+' ndata='+string(ndata))
   Def>end
flac3d>
flac3d>; --- gradual velocity drive of 'driven' gps toward stage target over creep_time ---
flac3d>fish define apply_vel_idw(creep_time, radius)
   Def>    loop foreach local g gp.list
   Def>        if gp.group(g,'drive') = 'driven' then
   Def>            local p = gp.pos(g)
   Def>            local x = comp.x(p)
   Def>            local y = comp.y(p)
   Def>            local z = comp.z(p)
   Def>            local sw = 0.0
   Def>            local sux = 0.0
   Def>            local suy = 0.0
   Def>            local suz = 0.0
   Def>            local dmin = 1e30
   Def>            local i = 1
   Def>            loop while i <= ndata
   Def>                local dx = x - xdat(i)
   Def>                local dy = y - ydat(i)
   Def>                local dz = z - zdat(i)
   Def>                local d2 = dx*dx + dy*dy + dz*dz
   Def>                if d2 <= radius*radius then
   Def>                    local w = 1.0/math.max(d2,1e-10)
   Def>                    sw = sw + w
   Def>                    sux = sux + uxdat(i)*w
   Def>                    suy = suy + uydat(i)*w
   Def>                    suz = suz + uzdat(i)*w
   Def>                end_if
   Def>                if d2 < dmin then
   Def>                    dmin = d2
   Def>                    global inear = i
   Def>                end_if
   Def>                i = i + 1
   Def>            end_loop
   Def>            local tx = 0.0
   Def>            local ty = 0.0
   Def>            local tz = 0.0
   Def>            if sw > 0.0 then
   Def>                tx = sux/sw
   Def>                ty = suy/sw
   Def>                tz = suz/sw
   Def>            else
   Def>                tx = uxdat(inear)
   Def>                ty = uydat(inear)
   Def>                tz = uzdat(inear)
   Def>            end_if
   Def>            local d = gp.disp(g)
   Def>            gp.vel(g) = vector((tx-comp.x(d))/creep_time, (ty-comp.y(d))/creep_time, (tz-comp.z(d))/creep_time)
   Def>            gp.fix(g) = vector(1,1,1)
   Def>        end_if
   Def>    end_loop
   Def>end
flac3d>
flac3d>; --- Maxwell-only threshold gating (Kelvin always on), corrected MC envelope, ONCE per stage ---
flac3d>fish define do_threshold
   Def>    local na = 0
   Def>    loop foreach local z zone.list
   Def>        if zone.group(z,'mat') = 'rock' then
   Def>            local s1 = -zone.stress.prin.x(z)
   Def>            local s3 = -zone.stress.prin.z(z)
   Def>            local pore = zone.pp(z)
   Def>            local pmean = (s1 + s3)/2.0 - pore
   Def>            local q = (s1 - s3)/2.0
   Def>            local c = zone.prop(z,'cohesion')
   Def>            local phi = zone.prop(z,'friction')
   Def>            local q_th = crp_threshold*(c*math.cos(phi*math.degrad) + pmean*math.sin(phi*math.degrad))
   Def>            if q >= q_th then
   Def>                zone.prop(z,'viscosity-maxwell') = eta_m
   Def>                na = na + 1
   Def>            else
   Def>                zone.prop(z,'viscosity-maxwell') = 1e100
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    global n_active = na
   Def>end
