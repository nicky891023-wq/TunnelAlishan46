flac3d>fish define midconv
   Def>    local s = 0.0
   Def>    local n = 0
   Def>    local mx = 0.0
   Def>    loop foreach local b ball.list
   Def>        local p = ball.pos(b)
   Def>        local yy = comp.y(p)
   Def>        if yy > 870.0 then
   Def>        if yy < 900.0 then
   Def>            local rx = comp.x(p) - 1297.0
   Def>            local rz = comp.z(p) - 1747.5
   Def>            local rr = math.sqrt(rx*rx + rz*rz)
   Def>            if rr > 1.35 then
   Def>            if rr < 2.05 then
   Def>                local d = ball.disp(b)
   Def>                local ur = (comp.x(d)*rx + comp.z(d)*rz)/rr
   Def>                s = s + ur
   Def>                n = n + 1
   Def>                if math.abs(ur) > mx then
   Def>                    mx = math.abs(ur)
   Def>                end_if
   Def>            end_if
   Def>            end_if
   Def>        end_if
   Def>        end_if
   Def>    end_loop
   Def>    global mc_mean = s/float(n)
   Def>    global mc_max = mx
   Def>    global mc_n = n
   Def>    midconv = mc_mean
   Def>end
