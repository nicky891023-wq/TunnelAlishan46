flac3d>fish define relax_legs(tagpfx, nlegs)
   Def>    local ileg = 0
   Def>    local dry = 0
   Def>    loop while ileg < nlegs
   Def>        ileg = ileg + 1
   Def>        if dry < 2 then
   Def>            command
   Def>                model cycle 600
   Def>            endcommand
   Def>            global ndeb = 0
   Def>            loop foreach local b ball.list
   Def>                local d = ball.disp(b)
   Def>                local m = math.sqrt(comp.x(d)^2+comp.y(d)^2+comp.z(d)^2)
   Def>                if m > 0.010 then
   Def>                    ball.group(b,'debris') = 'debris'
   Def>                    ndeb = ndeb + 1
   Def>                end_if
   Def>            end_loop
   Def>            command
   Def>                ball delete range group 'debris'
   Def>                model calm
   Def>            endcommand
   Def>            if ndeb = 0 then
   Def>                dry = dry + 1
   Def>            else
   Def>                dry = 0
   Def>            end_if
   Def>            local dmg = 0.0
   Def>            local px = 0.0
   Def>            local py = 0.0
   Def>            local pz = 0.0
   Def>            loop foreach local g gp.list
   Def>                local dg = gp.disp(g)
   Def>                local mg = math.sqrt(comp.x(dg)^2+comp.y(dg)^2+comp.z(dg)^2)
   Def>                if mg > dmg then
   Def>                    dmg = mg
   Def>                    local pp = gp.pos(g)
   Def>                    px = comp.x(pp)
   Def>                    py = comp.y(pp)
   Def>                    pz = comp.z(pp)
   Def>                end_if
   Def>            end_loop
   Def>            io.out(tagpfx+' leg'+string(ileg)+' swept='+string(ndeb)+' dry='+string(dry)+' gp_dmax='+string(dmg)+'m@('+string(px)+','+string(py)+','+string(pz)+') intact='+string(n_intact))
