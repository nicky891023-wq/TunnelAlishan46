flac3d>; ---- IDW full targets -> gp.extra(4,5,6) ----
flac3d>fish define set_full_targets(radius)
   Def>    loop foreach local g gp.list
   Def>        if gp.group(g,'drive') = 'driven' then
   Def>            local p = gp.pos(g)
   Def>            local x = comp.x(p)
   Def>            local y = comp.y(p)
   Def>            local z = comp.z(p)
   Def>            local sw = 0.0
   Def>            local sux = 0.0
   Def>            local suy = 0.0
   Def>            local suz = 0.0
   Def>            local dmin = 1e30
   Def>            local i = 1
   Def>            loop while i <= ndata
   Def>                local dx = x - xdat(i)
   Def>                local dy = y - ydat(i)
   Def>                local dz = z - zdat(i)
   Def>                local d2 = dx*dx + dy*dy + dz*dz
   Def>                if d2 <= radius*radius then
   Def>                    local w = 1.0/math.max(d2,1e-10)
   Def>                    sw = sw + w
   Def>                    sux = sux + uxdat(i)*w
   Def>                    suy = suy + uydat(i)*w
   Def>                    suz = suz + uzdat(i)*w
   Def>                end_if
   Def>                if d2 < dmin then
   Def>                    dmin = d2
   Def>                    global inear = i
   Def>                end_if
   Def>                i = i + 1
   Def>            end_loop
   Def>            if sw > 0.0 then
   Def>                gp.extra(g,4) = sux/sw
   Def>                gp.extra(g,5) = suy/sw
   Def>                gp.extra(g,6) = suz/sw
   Def>            else
   Def>                gp.extra(g,4) = uxdat(inear)
   Def>                gp.extra(g,5) = uydat(inear)
   Def>                gp.extra(g,6) = uzdat(inear)
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    io.out('CLD full targets set')
   Def>end
flac3d>fish define set_frac(frac)
   Def>    loop foreach local g gp.list
   Def>        if gp.group(g,'drive') = 'driven' then
   Def>            gp.extra(g,1) = frac*gp.extra(g,4)
