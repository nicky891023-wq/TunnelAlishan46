flac3d>fish define mid_wall_force(pfx, y0, y1)
   Def>    global fmid_sum = 0.0      ; signed sum of normal force (compression>0 per PFC convention varies)
   Def>    global fmid_abs = 0.0      ; sum |normal force| = contact-load magnitude proxy
   Def>    global nmid_c = 0
   Def>    ; coupling (ball-facet on wz_outter) = linearpbond unbreakable pb_ten>=1e10 (cb_control0 has NO
   Def>    ;   'bf_couple' group; identify by pb_ten instead verified 62556 coupling contacts, 47806 in mid)
   Def>    loop foreach local c contact.list
   Def>        if contact.model(c) = 'linearpbond' then
   Def>            if contact.prop(c,'pb_ten') >= 1.0e10 then
   Def>                local p = contact.pos(c)
   Def>                local yy = comp.y(p)
   Def>                if yy >= y0 then
   Def>                    if yy <= y1 then
   Def>                        local fn = contact.force.normal(c)
   Def>                        fmid_sum = fmid_sum + fn
   Def>                        local af = fn
   Def>                        if af < 0.0 then
   Def>                            af = -af
   Def>                        end_if
   Def>                        fmid_abs = fmid_abs + af
   Def>                        nmid_c = nmid_c + 1
   Def>                    end_if
   Def>                end_if
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    io.out('MID-WALL '+pfx+' y['+string(y0)+','+string(y1)+'] bf_couple_n='+string(nmid_c)+' sum_normal='+string(fmid_sum/1e6)+'MN abs_normal='+string(fmid_abs/1e6)+'MN')
   Def>end
