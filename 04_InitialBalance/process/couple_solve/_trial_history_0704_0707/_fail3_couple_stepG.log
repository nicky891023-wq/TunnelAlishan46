flac3d>fish define relax_legs(tagpfx, nlegs)
   Def>    local ileg = 0
   Def>    local dry = 0
   Def>    loop while ileg < nlegs
   Def>        ileg = ileg + 1
   Def>        if dry < 2 then
   Def>            command
   Def>                model cycle 800
   Def>            endcommand
   Def>            global ndeb = 0
   Def>            loop foreach local b ball.list
   Def>                local d = ball.disp(b)
   Def>                local m = math.sqrt(comp.x(d)^2+comp.y(d)^2+comp.z(d)^2)
   Def>                if m > 0.015 then
   Def>                    ball.group(b,'debris') = 'debris'
   Def>                    ndeb = ndeb + 1
   Def>                end_if
   Def>            end_loop
   Def>            command
   Def>                ball delete range group 'debris'
   Def>                model calm
   Def>            endcommand
   Def>            if ndeb = 0 then
   Def>                dry = dry + 1
   Def>            else
   Def>                dry = 0
   Def>            end_if
   Def>            io.out(tagpfx+' leg'+string(ileg)+' swept='+string(ndeb)+' dry='+string(dry)+' gp_dmax='+string(gpdmax)+'m intact='+string(n_intact))
   Def>        end_if
   Def>    end_loop
   Def>end
