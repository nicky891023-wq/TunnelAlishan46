flac3d>def ReadFile_ss(fname)
   Def>    local arr = array.create(1)
   Def>    ss_ndata = 0
   Def>    local stat = file.close
   Def>    stat = file.open(fname,0,1)
   Def>    if stat # 0 then
   Def>        io.out('ReadFile_ss: file.open failed status='+string(stat))
   Def>        exit
   Def>    endif
   Def>    stat = file.read(arr,1)            ; header
   Def>    stat = file.read(arr,1)            ; first data row
   Def>    loop while stat = 0
   Def>        ss_ndata = ss_ndata + 1
   Def>        stat = file.read(arr,1)
   Def>    endloop
   Def>    stat = file.close
   Def>    io.out('ReadFile_ss: data rows = '+string(ss_ndata))
   Def>    if ss_ndata <= 0 then
   Def>        exit
   Def>    endif
   Def>    ss_xdat = array.create(ss_ndata)
   Def>    ss_ydat = array.create(ss_ndata)
   Def>    ss_zdat = array.create(ss_ndata)
   Def>    sxxdat = array.create(ss_ndata)
   Def>    syydat = array.create(ss_ndata)
   Def>    szzdat = array.create(ss_ndata)
   Def>    sxydat = array.create(ss_ndata)
   Def>    sxzdat = array.create(ss_ndata)
   Def>    syzdat = array.create(ss_ndata)
   Def>    stat = file.open(fname,0,1)
   Def>    stat = file.read(arr,1)            ; skip header
   Def>    local i = 0
   Def>    stat = file.read(arr,1)
   Def>    loop while stat = 0
   Def>        i = i + 1
   Def>        local line = arr(1)
