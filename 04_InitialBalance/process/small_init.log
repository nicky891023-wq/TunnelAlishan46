flac3d>def MapStress_IDW(search_radius)
   Def>    local nmap = 0
   Def>    loop foreach local iz zone.list
   Def>        if zone.id(iz) > 0 then            ; ALL zones (rock + lining) -- wished-in-place
   Def>            local x = zone.pos.x(iz)
   Def>            local y = zone.pos.y(iz)
   Def>            local z = zone.pos.z(iz)
   Def>            local sum_w = 0.0
   Def>            local s_xx = 0.0
   Def>            local s_yy = 0.0
   Def>            local s_zz = 0.0
   Def>            local s_xy = 0.0
   Def>            local s_xz = 0.0
   Def>            local s_yz = 0.0
   Def>            local dmin = 1.0e30
   Def>            local inear = 1
   Def>            local i = 1
   Def>            loop while i <= ss_ndata
   Def>                local dx = math.abs(x - ss_xdat(i))
   Def>                if dx <= search_radius then
   Def>                    local dy = math.abs(y - ss_ydat(i))
   Def>                    if dy <= search_radius then
   Def>                        local dz = math.abs(z - ss_zdat(i))
   Def>                        if dz <= search_radius then
   Def>                            local d2 = dx*dx + dy*dy + dz*dz
   Def>                            if d2 <= (search_radius*search_radius) then
   Def>                                if d2 < dmin then
   Def>                                    dmin = d2
   Def>                                    inear = i
   Def>                                endif
   Def>                                local w = 1.0 / math.max(d2,1e-10)
   Def>                                sum_w = sum_w + w
   Def>                                s_xx = s_xx + sxxdat(i)*w
   Def>                                s_yy = s_yy + syydat(i)*w
   Def>                                s_zz = s_zz + szzdat(i)*w
   Def>                                s_xy = s_xy + sxydat(i)*w
   Def>                                s_xz = s_xz + sxzdat(i)*w
   Def>                                s_yz = s_yz + syzdat(i)*w
   Def>                            endif
   Def>                        endif
   Def>                    endif
   Def>                endif
   Def>                i = i + 1
   Def>            endloop
   Def>            if sum_w > 0.0 then
   Def>                zone.stress.xx(iz) = s_xx / sum_w
   Def>                zone.stress.yy(iz) = s_yy / sum_w
   Def>                zone.stress.zz(iz) = s_zz / sum_w
   Def>                zone.stress.xy(iz) = s_xy / sum_w
   Def>                zone.stress.xz(iz) = s_xz / sum_w
   Def>                zone.stress.yz(iz) = s_yz / sum_w
   Def>            else
   Def>                i = 1
   Def>                loop while i <= ss_ndata
   Def>                    local d2b = (x-ss_xdat(i))^2 + (y-ss_ydat(i))^2 + (z-ss_zdat(i))^2
   Def>                    if d2b < dmin then
   Def>                        dmin = d2b
   Def>                        inear = i
   Def>                    endif
   Def>                    i = i + 1
   Def>                endloop
   Def>                zone.stress.xx(iz) = sxxdat(inear)
   Def>                zone.stress.yy(iz) = syydat(inear)
   Def>                zone.stress.zz(iz) = szzdat(inear)
   Def>                zone.stress.xy(iz) = sxydat(inear)
   Def>                zone.stress.xz(iz) = sxzdat(inear)
   Def>                zone.stress.yz(iz) = syzdat(inear)
   Def>            endif
   Def>            nmap = nmap + 1
   Def>        endif
   Def>    endloop
   Def>    io.out('MapStress_IDW: mapped onto '+string(nmap)+' zones rock+lining (radius '+string(search_radius)+')')
   Def>end
