   Def>        structure shell recover stress depth-factor 0
   Def>    endcommand
   Def>    local mc = 0.0
   Def>    local mt = 0.0
   Def>    loop foreach local s struct.list
   Def>        if struct.type(s) = 'shell' then
   Def>            loop local k (0,3)
   Def>                local smn = struct.shell.stress.prin.x(s,k)
   Def>                local smx = struct.shell.stress.prin.z(s,k)
   Def>                if -smn > mc then
   Def>                    mc = -smn
   Def>                end_if
   Def>                if smx > mt then
   Def>                    mt = smx
   Def>                end_if
   Def>            end_loop
   Def>        end_if
   Def>    end_loop
   Def>    io.out('SI-shell install max_comp='+string(mc/1e6)+'MPa max_tension='+string(mt/1e6)+'MPa (cap fc=41.2/ft=4.12)')
