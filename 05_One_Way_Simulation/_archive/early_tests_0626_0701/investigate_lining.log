flac3d>fish define dwall      ; max |disp| within r<5m (tunnel-wall convergence)
   Def>    local dm = 0.0
   Def>    loop foreach local gp gp.list
   Def>        local p = gp.pos(gp)
   Def>        local dx = comp.x(p)-1299.0
   Def>        local dz = comp.z(p)-1747.0
   Def>        if math.sqrt(dx*dx+dz*dz) < 5.0 then
   Def>            local d = gp.disp(gp)
   Def>            local mm = math.sqrt(comp.x(d)*comp.x(d)+comp.y(d)*comp.y(d)+comp.z(d)*comp.z(d))
   Def>            if mm > dm then
   Def>                dm = mm
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    dwall = dm
   Def>end
flac3d>fish define lin_stress   ; max compression (sig1) + max tension (-sig3) in the lining ring
   Def>    local smax = 0.0
   Def>    local tmax = 0.0
   Def>    local nl = 0
   Def>    loop foreach local z zone.list
   Def>        if zone.group(z,'type') = 'lining' then
   Def>            nl = nl + 1
   Def>            local s1 = -zone.stress.prin.x(z)   ; compression+
   Def>            local s3 = -zone.stress.prin.z(z)
   Def>            if s1 > smax then
   Def>                smax = s1
   Def>            end_if
   Def>            if (-s3) > tmax then
   Def>                tmax = -s3                       ; tension magnitude
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    global lin_n = nl
   Def>    global lin_smax = smax
   Def>    global lin_tmax = tmax
   Def>end
flac3d>[global threhold = 0.4]
flac3d>fish define do_threshold
   Def>    local na = 0
   Def>    loop foreach local z zone.list
   Def>        if zone.group(z,'mat') = 'rock' then
   Def>            local s1 = -zone.stress.prin.x(z)
   Def>            local s3 = -zone.stress.prin.z(z)
   Def>            local pore = zone.pp(z)
   Def>            local pmean = (s1 + s3)/2.0 - pore
   Def>            local q = (s1 - s3)/2.0
   Def>            local c = zone.prop(z,'cohesion')
   Def>            local phi = zone.prop(z,'friction')
   Def>            local q_th = threhold*c + pmean*threhold*math.tan(phi*math.degrad)
   Def>            if q >= q_th then
   Def>                zone.prop(z,'viscosity-kelvin')  = eta_k
   Def>                zone.prop(z,'viscosity-maxwell') = eta_m
   Def>                zone.group(z,'creep') = 'CreepActive'
   Def>                na = na + 1
   Def>            else
   Def>                zone.prop(z,'viscosity-kelvin')  = 1e100
   Def>                zone.prop(z,'viscosity-maxwell') = 1e100
   Def>                zone.group(z,'creep') = 'CreepOff'
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    global n_active = na
   Def>end
