; track_e_water_08.f3dat -- FULL FIX validation: per-stage threshold (stability, Track C) +
;   zone water density (the omission that broke pp in C/D) + threshold 0.8 (Wade's pick, strong
;   onset). Measure per-stage creep displacement (disp zeroed after each re-eq) to show the
;   flat-then-onset. low z1724 (dry tunnel, ~20% active) vs high z1807 (saturated, ~48% active).
;   restore small_ep. cwd = 05.
program log-file 'track_e.log'
program log on
model restore 'small_ep'
call '../04_InitialBalance/parameter.f3dat'
model largestrain off
fish automatic-create on
zone water density [rho_w]      ; <<< THE FIX that was missing in C/D (pp was 0)
[io.out('TE0 restored small_ep + water density set; zones='+string(zone.num))]

fish define dmax_all
    local dm = 0.0
    loop foreach local gp gp.list
        local d = gp.disp(gp)
        local mm = math.sqrt(comp.x(d)*comp.x(d)+comp.y(d)*comp.y(d)+comp.z(d)*comp.z(d))
        if mm > dm then
            dm = mm
        end_if
    end_loop
    dmax_all = dm
end
[global threhold = 0.8]
fish define do_threshold
    local na = 0
    loop foreach local z zone.list
        if zone.group(z,'mat') = 'rock' then
            local s1 = -zone.stress.prin.x(z)
            local s3 = -zone.stress.prin.z(z)
            local pore = zone.pp(z)
            local pmean = (s1 + s3)/2.0 - pore
            local q = (s1 - s3)/2.0
            local c = zone.prop(z,'cohesion')
            local phi = zone.prop(z,'friction')
            local q_th = threhold*c + pmean*threhold*math.tan(phi*math.degrad)
            if q >= q_th then
                zone.prop(z,'viscosity-kelvin')  = eta_k
                zone.prop(z,'viscosity-maxwell') = eta_m
                zone.group(z,'creep') = 'CreepActive'
                na = na + 1
            else
                zone.prop(z,'viscosity-kelvin')  = 1e100
                zone.prop(z,'viscosity-maxwell') = 1e100
                zone.group(z,'creep') = 'CreepOff'
            end_if
        end_if
    end_loop
    global n_active = na
end
fish define run_stage(d0, d1, dd)
    local d = d0 + dd
    loop while d <= (d1 + 0.1)
        command
            model solve time-total [d*86400.0]
        endcommand
        io.out('   TEcreep day='+string(d)+' dmax='+string(dmax_all)+' m  (active='+string(n_active)+')')
        d = d + dd
    endloop
end
model history creep time-total
zone history name 'crown_dz' displacement-z position (1297, 885, 1752)
zone history name 'side_dx'  displacement-x position (1303, 885, 1747)

; === STAGE 1: LOW water z1724 (dry tunnel) ===
zone water plane origin (1297, 885, 1724) normal (0,0,1)
model calm
model solve ratio-average 1e-5 cycles 40000
[setKstrains]
[do_threshold]
[setKstrains]
zone gridpoint initialize displacement 0 0 0
zone gridpoint initialize velocity 0 0 0
[io.out('TE-S1eq LOW-water 0.8 ONCE; active='+string(n_active)+' (expect ~20% -> small flat creep)')]
model creep active on
model creep timestep fix [crp_dt]
[run_stage(0.0, 30.0, 5.0)]
model creep active off
model save 'te_s1'
[io.out('TE-S1done LOW creep 30d dmax='+string(dmax_all))]

; === STAGE 2: HIGH water z1807 (saturated) -- disp re-zeroed => stage-2 creep alone ===
zone water plane origin (1297, 885, 1807) normal (0,0,1)
model calm
model solve ratio-average 1e-5 cycles 40000
[setKstrains]
[do_threshold]
[setKstrains]
zone gridpoint initialize displacement 0 0 0
zone gridpoint initialize velocity 0 0 0
[io.out('TE-S2eq HIGH-water 0.8 ONCE; active='+string(n_active)+' (expect ~48% -> larger ONSET creep)')]
model creep active on
model creep timestep fix [crp_dt]
[run_stage(30.0, 60.0, 5.0)]
model creep active off
model save 'te_s2'
[io.out('TE-DONE 0.8: S1(low) vs S2(high) creep dmax = flat-then-onset?')]
program log off
program quit
