   Def>    global crack_accum = 0
   Def>    global crack_num = 0
   Def>    global track_time0 = mech.time.total
   Def>    global frag_time = mech.time.total
   Def>    global xmin = domain.min.x()
   Def>    global ymin = domain.min.y()
   Def>    global xmax = domain.max.x()
   Def>    global ymax = domain.max.y()
   Def>    global zmin = domain.min.z()
   Def>    global zmax = domain.max.z()
   Def>
   Def>end
