flac3d>fish define track_init
   Def>    command
   Def>        fracture delete
   Def>        model results clear-map
   Def>        fragment clear
   Def>        fragment register ball-ball
   Def>    endcommand
   Def>  ; activate fishcalls
   Def>    command
   Def>        fish callback remove add_crack event bond_break
   Def>        fish callback add add_crack event bond_break
   Def>    endcommand
