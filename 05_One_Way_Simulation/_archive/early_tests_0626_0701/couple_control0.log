flac3d>
flac3d>fish define add_crack(entries)
   Def>    local contact    = entries(1)
   Def>    local mode       = entries(3)
   Def>    local  frac_pos   = contact.pos(contact)
   Def>    local norm       = contact.normal(contact)
   Def>    local dfn_label  = 'crack'
   Def>    local  frac_size
   Def>    local  bp1 = contact.end1(contact)
   Def>    local  bp2 = contact.end2(contact)
   Def>    local  ret = math.min(ball.radius(bp1),ball.radius(bp2))
   Def>                 ; (  contact.method(contact,'pb_radius')  )
   Def>    frac_size = ret
   Def>    local arg = array.create(5)
   Def>    arg(1) = 'disk'
   Def>    arg(2) = frac_pos
   Def>    arg(3) = frac_size
   Def>    arg(4) = math.dip.from.normal(norm)/math.degrad
   Def>    arg(5) = math.ddir.from.normal(norm)/math.degrad
   Def>    if arg(5) < 0.0
   Def>      arg(5) = 360.0+arg(5)
   Def>    end_if
   Def>    global crack_num
   Def>    crack_num = crack_num + 1
   Def>    
   Def>    if mode = 1 then 
   Def>        ; failed in tension
   Def>        dfn_label = dfn_label + '_tension'
   Def>    else if mode = 2 then
   Def>        ; failed in shear
   Def>        dfn_label = dfn_label + '_shear'
   Def>    endif
   Def>        
   Def>    global dfn = dfn.find(dfn_label)
   Def>    if dfn = null then
   Def>        dfn = dfn.create(dfn_label)
   Def>    endif
   Def>    local fnew = fracture.create(dfn,arg)
   Def>    fracture.prop(fnew,'age')  = mech.time.total
   Def>    fracture.extra(fnew,1) = bp1
   Def>    fracture.extra(fnew,2) = bp2
   Def>    crack_accum += 1
   Def>    global frag_time
   Def>    global xmin,xmax,ymin,ymax,zmin,zmax
   Def>    if crack_accum > 50
   Def>        if frag_time < mech.time.total
   Def>            frag_time = mech.time.total
   Def>            crack_accum = 0
   Def>            command 
   Def>                fragment compute
   Def>            endcommand
   Def>            ; go through and update the fracture positions
   Def>            loop for (local i = 0, i < 2, i = i + 1)
   Def>                local name = 'crack_tension'
   Def>                if i = 1
   Def>                    name = 'crack_shear'
   Def>                endif
   Def>                dfn = dfn.find(name)
   Def>                if dfn # null
   Def>                    loop foreach local frac dfn.fracturelist(dfn)
   Def>                        local ball1 = fracture.extra(frac,1)
   Def>                        local ball2 = fracture.extra(frac,2)
   Def>                        if ball1 # null
   Def>                            if ball2 # null
   Def>                                local len = fracture.diameter(frac)/2.0
   Def>                                local pos = (ball.pos(ball1)+ ...
   Def>                                             ball.pos(ball2))/2.0
   Def>                                if comp.x(pos)-len > xmin
   Def>                                    if comp.x(pos)+len < xmax
   Def>                                        if comp.y(pos)-len > ymin
   Def>                                            if comp.y(pos)+len < ymax
   Def>                                                if comp.z(pos)-len > zmin
   Def>                                                    if comp.z(pos)+len < zmax
   Def>                                                       fracture.pos(frac) = pos
   Def>                                                    end_if
   Def>                                                end_if
   Def>                                            endif
   Def>                                        endif
   Def>                                    endif
   Def>                                endif
   Def>                            endif
   Def>                        endif
   Def>                    endloop
   Def>                endif
   Def>            endloop
   Def>        endif
   Def>    endif
   Def>end
