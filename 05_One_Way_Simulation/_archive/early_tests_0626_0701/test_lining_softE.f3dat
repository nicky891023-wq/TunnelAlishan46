; test_lining_softE.f3dat -- Wade: reduce lining stiffness (cracked concrete) to relieve the
;   over-support. Lining elastic E 25GPa -> 6GPa (~0.25x, heavily-cracked RC effective modulus).
;   Re-solve in-situ (so the locked-in 57MPa drops to physical) then creep -> does the wall
;   convergence increase + the lining stress drop to physical? restore small_ep. cwd = 05.
program log-file 'test_lining_softE.log'
program log on
model restore 'small_ep'
call '../04_InitialBalance/parameter.f3dat'
model largestrain off
fish automatic-create on
zone water density [rho_w]
[global Esoft = 6.0e9]
[io.out('LS-0 restored small_ep; reducing lining E 25GPa -> '+string(Esoft/1e9)+'GPa')]

fish define lin_stress
    local smax = 0.0
    local tmax = 0.0
    local nl = 0
    loop foreach local z zone.list
        if zone.group(z,'type') = 'lining' then
            nl = nl + 1
            local s1 = -zone.stress.prin.x(z)
            local s3 = -zone.stress.prin.z(z)
            if s1 > smax then
                smax = s1
            end_if
            if (-s3) > tmax then
                tmax = -s3
            end_if
        end_if
    end_loop
    global lin_n = nl
    global lin_smax = smax
    global lin_tmax = tmax
end
fish define dwall
    local dm = 0.0
    loop foreach local gp gp.list
        local p = gp.pos(gp)
        local dx = comp.x(p)-1299.0
        local dz = comp.z(p)-1747.0
        if math.sqrt(dx*dx+dz*dz) < 5.0 then
            local d = gp.disp(gp)
            local mm = math.sqrt(comp.x(d)*comp.x(d)+comp.y(d)*comp.y(d)+comp.z(d)*comp.z(d))
            if mm > dm then
                dm = mm
            end_if
        end_if
    end_loop
    dwall = dm
end
[global threhold = 0.4]
fish define do_threshold
    local na = 0
    loop foreach local z zone.list
        if zone.group(z,'mat') = 'rock' then
            local s1 = -zone.stress.prin.x(z)
            local s3 = -zone.stress.prin.z(z)
            local pore = zone.pp(z)
            local pmean = (s1 + s3)/2.0 - pore
            local q = (s1 - s3)/2.0
            local c = zone.prop(z,'cohesion')
            local phi = zone.prop(z,'friction')
            local q_th = threhold*c + pmean*threhold*math.tan(phi*math.degrad)
            if q >= q_th then
                zone.prop(z,'viscosity-kelvin')  = eta_k
                zone.prop(z,'viscosity-maxwell') = eta_m
                zone.group(z,'creep') = 'CreepActive'
                na = na + 1
            else
                zone.prop(z,'viscosity-kelvin')  = 1e100
                zone.prop(z,'viscosity-maxwell') = 1e100
                zone.group(z,'creep') = 'CreepOff'
            end_if
        end_if
    end_loop
    global n_active = na
end

; --- reduce lining stiffness + re-solve in-situ ---
zone property bulk [Esoft/(3.0*(1.0-2.0*shot_v))] shear [Esoft/(2.0*(1.0+shot_v))] range group 'lining' slot 'type'
[lin_stress]
[io.out('LS-1 before re-solve: lin_comp='+string(lin_smax/1e6)+'MPa lin_ten='+string(lin_tmax/1e6)+'MPa')]
model solve ratio-average 1e-5 cycles 40000
[lin_stress]
[io.out('LS-2 after re-solve (softer lining in-situ): lin_comp='+string(lin_smax/1e6)+'MPa lin_ten='+string(lin_tmax/1e6)+'MPa (vs 57/13.75 at 25GPa)')]

; --- high water + threshold 0.4 + creep ---
zone water plane origin (1297, 885, 1807) normal (0,0,1)
model calm
model solve ratio-average 1e-5 cycles 40000
[setKstrains]
[do_threshold]
[setKstrains]
zone gridpoint initialize displacement 0 0 0
zone gridpoint initialize velocity 0 0 0
[io.out('LS-EQ HIGH-water 0.4 active='+string(n_active))]
model creep active on
model creep timestep fix [crp_dt]
fish define run_ls(d0, d1, dd)
    local d = d0 + dd
    loop while d <= (d1 + 0.1)
        command
            model solve time-total [d*86400.0]
        endcommand
        lin_stress
        io.out('   LS day='+string(d)+' wall_conv='+string(dwall)+' lin_comp='+string(lin_smax/1e6)+'MPa lin_ten='+string(lin_tmax/1e6)+'MPa')
        d = d + dd
    endloop
end
[run_ls(0.0, 60.0, 10.0)]
[io.out('LS-DONE E=6GPa: wall_conv vs 0.8 standalone ~2.5mm? lining stress physical?')]
program log off
program quit
