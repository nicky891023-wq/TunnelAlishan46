flac3d>; --- per-stage ramp (cumulative target gp.extra(.,stg)), mid breaker y870-900 ---
flac3d>fish define ramp_stage(stg, nsub, ncyc)
   Def>    global abort_flag = 0
   Def>    mid_count(870.0, 900.0)
   Def>    global prev_mid = n_mid
   Def>    local j = 1
   Def>    loop while j <= nsub
   Def>        local subs_left = float(nsub-j+1)
   Def>        loop foreach local g gp.list
   Def>            if gp.group(g,'drive') = 'driven' then
   Def>                local rem = gp.extra(g,stg) - gp.disp(g)
   Def>                if gp.group(g,'cap') = 'ycap' then
   Def>                    rem = vector(comp.x(rem), 0.0, comp.z(rem))
   Def>                end_if
   Def>                gp.vel(g) = rem/(subs_left*float(ncyc)*dt_now)
   Def>            end_if
   Def>        end_loop
   Def>        command
   Def>            model cycle [ncyc]
   Def>        endcommand
   Def>        mid_count(870.0, 900.0)
   Def>        local dmid = n_mid - prev_mid
   Def>        if dmid > 50 then
   Def>            io.out('FULL-MID-BREAK s'+string(stg)+' dmid='+string(dmid)+'>50 at j='+string(j))
   Def>            abort_flag = 1
   Def>            exit
   Def>        end_if
   Def>        prev_mid = n_mid
   Def>        j = j + 1
   Def>    end_loop
   Def>    io.out('   FULL-ramp s'+string(stg)+' done BLUELINE='+string(n_mid)+' corner(excl)='+string(n_corner)+' yend(excl)='+string(n_end)+' total='+string(crack_num-base_cracks)+' abort='+string(abort_flag))
   Def>end
flac3d>
flac3d>fish define do_stage(stg)
   Def>    ramp_stage(stg, 30, 10)
   Def>    command
   Def>        zone gridpoint fix velocity 0 0 0 range group 'driven' slot 'drive'
   Def>    endcommand
   Def>    if abort_flag = 0 then
   Def>        command
   Def>            model solve ratio-average 1e-4 cycles 3000
   Def>        endcommand
   Def>    end_if
   Def>    maxbvel
   Def>    wall_forces
   Def>    mid_count(870.0, 900.0)
   Def>    local pfx = 'full_s'+string(stg)
   Def>    dump_cracks(pfx)
   Def>    crack_sectors(pfx)
   Def>    mid_wall_force(pfx, 870.0, 900.0)
   Def>    mid_convergence(pfx, 870.0, 900.0)
   Def>    io.out('FULL-RESULT-s'+string(stg)+' abort='+string(abort_flag)+' BLUELINE_cracks='+string(n_mid)+' fixedcorner_cracks(excl)='+string(n_corner)+' yend_cracks(excl)='+string(n_end)+' wz_total='+string(wzN)+'MN w_inner='+string(wiN)+'MN maxbvel='+string(mbv))
   Def>    local sname = 'cb_full_s'+string(stg)
   Def>    if abort_flag = 1 then
   Def>        sname = 'cb_full_s'+string(stg)+'_BREAK'
   Def>    end_if
   Def>    command
   Def>        model save [sname]
   Def>    endcommand
   Def>    io.out('FULL-SAVED s'+string(stg)+' -> '+sname)
   Def>end
