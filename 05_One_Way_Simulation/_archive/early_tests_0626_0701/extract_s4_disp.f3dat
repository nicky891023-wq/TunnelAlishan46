; extract_s4_disp.f3dat -- crown_dz=0.089mm tiny but global dmax=5.28mm. WHERE is the 5.28mm?
;   (tunnel EDZ side? mapped over-stress region? boundary?) Restore s4_s4, report max-disp gp
;   position + crown/side disp, export y~885 gp disp slice for plotting. cwd = 05.
program log-file 'extract_s4_disp.log'
program log on
model restore 's4_s4'
fish automatic-create on
fish define _ex
    local dmax = 0.0
    local xmx = 0.0
    local ymx = 0.0
    local zmx = 0.0
    loop foreach local gp gp.list
        local d = gp.disp(gp)
        local mm = math.sqrt(comp.x(d)*comp.x(d)+comp.y(d)*comp.y(d)+comp.z(d)*comp.z(d))
        if mm > dmax then
            dmax = mm
            local p = gp.pos(gp)
            xmx = comp.x(p)
            ymx = comp.y(p)
            zmx = comp.z(p)
        end_if
    end_loop
    io.out('EX-MAX dmax='+string(dmax)+' m at (x='+string(xmx)+', y='+string(ymx)+', z='+string(zmx)+')')
    ; export y~885 gp disp slice
    local fo = file.open('s4_disp_y885.txt',1,1)
    local a = array.create(1)
    a(1) = 'x z dmag dz'
    fo = file.write(a,1)
    loop foreach local g2 gp.list
        local p2 = gp.pos(g2)
        if comp.y(p2) > 884.0 then
        if comp.y(p2) < 886.0 then
            local d2 = gp.disp(g2)
            local m2 = math.sqrt(comp.x(d2)*comp.x(d2)+comp.y(d2)*comp.y(d2)+comp.z(d2)*comp.z(d2))
            a(1) = string(comp.x(p2))+' '+string(comp.z(p2))+' '+string(m2)+' '+string(comp.z(d2))
            fo = file.write(a,1)
        end_if
        end_if
    end_loop
    fo = file.close
    io.out('EX-EXP exported s4_disp_y885.txt')
end
[_ex]
[io.out('EX-DONE')]
program quit
