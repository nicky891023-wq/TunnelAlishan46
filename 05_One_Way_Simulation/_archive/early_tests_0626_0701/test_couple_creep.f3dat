; test_couple_creep.f3dat -- SHORT verify of the COUPLED creep mechanism: rock burgers-mohr
;   threshold creep -> wz_outter drives the PFC lining -> bonds break = cracks (bond_break->DFN).
;   Couple_Initial: 424908 rock zones (all 'rock' slot mat; layers2-6 slot type), 456302 balls,
;   walls wz_outter/w_inner/w_860/w_910. largestrain ON (PFC coupling). 1 stage low water, short.
;   cwd = 05.
program log-file 'test_couple_creep.log'
program log on
program load module 'pfc'
program load module 'wallzone'
model restore '../04_InitialBalance/Couple_Initial'
call '../04_InitialBalance/parameter.f3dat'
model largestrain on
model configure creep
fish automatic-create on
[io.out('CC0 restored Couple_Initial; zones='+string(zone.num)+' balls='+string(ball.num))]

; burgers-mohr on rock layers 2-6 (slot type); lining = PFC balls (keep D7 bonds, NOT zones)
zone cmodel assign burgers-mohr range group 'rock' slot 'mat'
zone property bulk [_bk(E_S_2)] shear-maxwell [_gk(E_S_2)] shear-kelvin [_gk(E_S_2)] viscosity-maxwell [eta_m] viscosity-kelvin [eta_k] cohesion [co_S_2] friction [fr_S_2] tension [ten_r] range group 'layer2' slot 'type'
zone property bulk [_bk(E_S_3)] shear-maxwell [_gk(E_S_3)] shear-kelvin [_gk(E_S_3)] viscosity-maxwell [eta_m] viscosity-kelvin [eta_k] cohesion [co_S_3] friction [fr_S_3] tension [ten_r] range group 'layer3' slot 'type'
zone property bulk [_bk(E_S_4)] shear-maxwell [_gk(E_S_4)] shear-kelvin [_gk(E_S_4)] viscosity-maxwell [eta_m] viscosity-kelvin [eta_k] cohesion [co_S_4] friction [fr_S_4] tension [ten_r] range group 'layer4' slot 'type'
zone property bulk [_bk(E_S_5)] shear-maxwell [_gk(E_S_5)] shear-kelvin [_gk(E_S_5)] viscosity-maxwell [eta_m] viscosity-kelvin [eta_k] cohesion [co_S_5] friction [fr_S_5] tension [ten_r] range group 'layer5' slot 'type'
zone property bulk [_bk(E_S_6)] shear-maxwell [_gk(E_S_6)] shear-kelvin [_gk(E_S_6)] viscosity-maxwell [eta_m] viscosity-kelvin [eta_k] cohesion [co_S_6] friction [fr_S_6] tension [ten_r] range group 'layer6' slot 'type'
model creep active off
[io.out('CC1 burgers-mohr on rock layers (lining=PFC balls)')]

; --- crack tracking (official bond_break -> DFN) ---
call 'fracture_track.fis'
[track_init]
[io.out('CC2 crack tracking armed (bond_break callback)')]

; --- monitors ---
fish define count_cracks
    global ncrk = crack_num    ; crack_num is incremented per bond_break in fracture_track.fis add_crack
end
fish define wz_force
    loop foreach local w wall.list
        if wall.name(w) = 'wz_outter' then
            local fc = wall.force.contact(w)
            global wzf = math.sqrt(comp.x(fc)*comp.x(fc)+comp.y(fc)*comp.y(fc)+comp.z(fc)*comp.z(fc))
        end_if
    end_loop
end
[global threhold = 0.6]
fish define do_threshold
    local na = 0
    loop foreach local z zone.list
        if zone.group(z,'mat') = 'rock' then
            local s1 = -zone.stress.prin.x(z)
            local s3 = -zone.stress.prin.z(z)
            local pore = zone.pp(z)
            local pmean = (s1 + s3)/2.0 - pore
            local q = (s1 - s3)/2.0
            local c = zone.prop(z,'cohesion')
            local phi = zone.prop(z,'friction')
            local q_th = threhold*c + pmean*threhold*math.tan(phi*math.degrad)
            if q >= q_th then
                zone.prop(z,'viscosity-kelvin')  = eta_k
                zone.prop(z,'viscosity-maxwell') = eta_m
                zone.group(z,'creep') = 'CreepActive'
                na = na + 1
            else
                zone.prop(z,'viscosity-kelvin')  = 1e100
                zone.prop(z,'viscosity-maxwell') = 1e100
                zone.group(z,'creep') = 'CreepOff'
            end_if
        end_if
    end_loop
    global n_active = na
end

; --- low water + coupled re-eq (ratio-average; PFC-safe timestep) ---
zone water density [rho_w]
zone water plane origin (1297, 885, 1724) normal (0,0,1)
model calm
ball attribute damp 0.7
zone mechanical damping local 0.8
model solve ratio-average 2e-3 cycles 4000   ; looser+lower cap for SHORT verify (re-eq full convergence is slow w/ 456k balls)
[wz_force]
[io.out('CC-EQ low-water coupled re-eq done; wz_outter force='+string(wzf/1e6)+'MN')]
[setKstrains]
[do_threshold]
[setKstrains]
[io.out('CC-S1eq active='+string(n_active)+' (rock creep-active)')]

; --- short creep (6 days, 2-day steps), watch cracks + wz force ---
model creep active on
model creep timestep fix [crp_dt]
fish define run_cc(d0, d1, dd)
    local d = d0 + dd
    loop while d <= (d1 + 0.1)
        command
            model solve time-total [d*86400.0]
        endcommand
        count_cracks
        wz_force
        io.out('   CCcreep day='+string(d)+' cracks='+string(ncrk)+' wz_force='+string(wzf/1e6)+'MN (active='+string(n_active)+')')
        d = d + dd
    endloop
end
[run_cc(0.0, 2.0, 1.0)]
[count_cracks]
[io.out('CC-DONE short test: cracks='+string(ncrk)+' (bond_break->DFN works? coupled creep stable?)')]
program log off
program quit
