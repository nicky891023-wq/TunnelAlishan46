flac3d>fish define diag_run(nsub, ncyc)
   Def>    global diag_stop = 0
   Def>    local j = 1
   Def>    loop while j <= nsub
   Def>        local subs_left = float(nsub-j+1)
   Def>        loop foreach local g gp.list
   Def>            if gp.group(g,'drive') = 'driven' then
   Def>                local rem = gp.extra(g,1) - gp.disp(g)
   Def>                gp.vel(g) = rem/(subs_left*float(ncyc)*dt_now)
   Def>            end_if
   Def>        end_loop
   Def>        command
   Def>            model cycle [ncyc]
   Def>        endcommand
   Def>        maxbvel
   Def>        ct_split
   Def>        local cum = crack_num - base_cracks
   Def>        io.out('   SMD-sub j='+string(j)+'/'+string(nsub)+' cum='+string(cum)+' tension='+string(nt)+' shear='+string(ns)+' maxbvel='+string(mbv))
   Def>        command
   Def>            model calm
   Def>        endcommand
   Def>        if cum > 500 then
   Def>            io.out('SMD-STOP cum='+string(cum)+'>500 at j='+string(j)+' (onset captured)')
   Def>            diag_stop = 1
   Def>            exit
   Def>        end_if
   Def>        j = j + 1
   Def>    end_loop
   Def>end
