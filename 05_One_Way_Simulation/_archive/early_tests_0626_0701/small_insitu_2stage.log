flac3d>; --- shell coverage QA: count (should stay ~68-72k = cavity wall; a jump means box planes leaked in) + y-extent ---
flac3d>fish define shell_extent
   Def>    local ns = 0
   Def>    local ymn = 1e30
   Def>    local ymx = -1e30
   Def>    loop foreach local s struct.list
   Def>        if struct.type(s) = 'shell' then
   Def>            ns = ns + 1
   Def>            local sy = struct.pos.y(s)
   Def>            if sy < ymn then
   Def>                ymn = sy
   Def>            end_if
   Def>            if sy > ymx then
   Def>                ymx = sy
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    io.out('SI2-3 shell installed; shells='+string(ns)+' y-extent=['+string(ymn)+','+string(ymx)+'] (tunnel ends covered if ~850.1/949.9; box-plane leak if count>>68k)')
   Def>end
