flac3d>fish define qa_rock(tag)
   Def>    local maxprin = -1e30
   Def>    local nten = 0
   Def>    local nplas = 0
   Def>    local nplas_tun = 0
   Def>    loop foreach local z zone.list
   Def>        if zone.model(z) # 'null' then
   Def>            local pz = zone.stress.prin.z(z)
   Def>            if pz > maxprin then
   Def>                maxprin = pz
   Def>            end_if
   Def>            if pz > 1000.0 then
   Def>                nten = nten + 1
   Def>            end_if
   Def>            if zone.state(z,1) # 0 then
   Def>                nplas = nplas + 1
   Def>                local rx = zone.pos.x(z)-1297.0
   Def>                local rz = zone.pos.z(z)-1747.5
   Def>                if math.sqrt(rx*rx+rz*rz) < 15.0 then
   Def>                    nplas_tun = nplas_tun + 1
   Def>                end_if
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    local mv = 0.0
   Def>    local mdsp = 0.0
   Def>    loop foreach local g gp.list
   Def>        local v = gp.vel(g)
   Def>        local m = math.sqrt(comp.x(v)^2+comp.y(v)^2+comp.z(v)^2)
   Def>        if m > mv then
   Def>            mv = m
   Def>        end_if
   Def>        local d = gp.disp(g)
   Def>        local md = math.sqrt(comp.x(d)^2+comp.y(d)^2+comp.z(d)^2)
   Def>        if md > mdsp then
   Def>            mdsp = md
   Def>        end_if
   Def>    end_loop
   Def>    io.out('SI2-QA-ROCK '+tag+' max_principal='+string(maxprin)+'Pa tension='+string(nten)+' plastic='+string(nplas)+' plastic_near_tunnel(r<15)='+string(nplas_tun)+' max_vel='+string(mv)+' max_disp='+string(mdsp*1000.0)+'mm')
   Def>end
flac3d>fish define qa_shell(tag)
   Def>    command
   Def>        structure shell recover surface (0,1,0)
   Def>        structure shell recover stress depth-factor 0
   Def>    endcommand
   Def>    local maxc = 0.0
   Def>    local maxt = 0.0
   Def>    loop foreach local s struct.list
   Def>        loop local k (0,3)
   Def>            local smin = struct.shell.stress.prin.x(s,k)
   Def>            local smax = struct.shell.stress.prin.z(s,k)
   Def>            if -smin > maxc then
   Def>                maxc = -smin
   Def>            end_if
   Def>            if smax > maxt then
   Def>                maxt = smax
   Def>            end_if
   Def>        end_loop
   Def>    end_loop
   Def>    io.out('SI2-QA-SHELL '+tag+' max_comp='+string(maxc/1e6)+'MPa max_tension='+string(maxt/1e6)+'MPa (cap 41.2/4.12) shells='+string(struct.num))
   Def>end
