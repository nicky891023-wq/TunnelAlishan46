flac3d>fish define face_disp(comp_idx, lo, hi, tag)
   Def>    local s = 0.0
   Def>    local n = 0
   Def>    local mx = -1e20
   Def>    local mn = 1e20
   Def>    loop foreach local g gp.list
   Def>        local p = gp.pos(g)
   Def>        local cc = comp.x(p)
   Def>        if comp_idx = 2 then
   Def>            cc = comp.y(p)
   Def>        end_if
   Def>        if comp_idx = 3 then
   Def>            cc = comp.z(p)
   Def>        end_if
   Def>        if cc >= lo then
   Def>        if cc <= hi then
   Def>            local d = gp.disp(g)
   Def>            local dv = comp.x(d)
   Def>            if comp_idx = 2 then
   Def>                dv = comp.y(d)
   Def>            end_if
   Def>            if comp_idx = 3 then
   Def>                dv = comp.z(d)
   Def>            end_if
   Def>            s = s + dv
   Def>            n = n + 1
   Def>            if dv > mx then
   Def>                mx = dv
   Def>            end_if
   Def>            if dv < mn then
   Def>                mn = dv
   Def>            end_if
   Def>        end_if
   Def>        end_if
   Def>    end_loop
   Def>    local m = 0.0
   Def>    if n > 0 then
   Def>        m = s/float(n)
   Def>    end_if
   Def>    io.out('LBND '+tag+' n='+string(n)+' mean_disp='+string(m*1000.0)+'mm [min'+string(mn*1000.0)+',max'+string(mx*1000.0)+']')
   Def>    global lastmean = m
   Def>end
