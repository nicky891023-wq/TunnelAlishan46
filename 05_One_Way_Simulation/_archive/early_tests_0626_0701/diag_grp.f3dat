program log-file 'diag_grp.log'
program log on
fish automatic-create on
model restore 's4_s1'
fish define diag
    local cx=1297.0
    local cz=1747.0
    local hist=array.create(10)
    local i=1
    loop while i<=10
        hist(i)=0
        i=i+1
    end_loop
    local nlin=0
    loop foreach local z zone.list
        if zone.group(z,'type')='lining' then
            nlin=nlin+1
            local p=zone.pos(z)
            local r=math.sqrt((comp.x(p)-cx)*(comp.x(p)-cx)+(comp.z(p)-cz)*(comp.z(p)-cz))
            local b=int(r)+1
            if b>10 then
                b=10
            end_if
            if b<1 then
                b=1
            end_if
            hist(b)=hist(b)+1
        end_if
    end_loop
    io.out('LINING n='+string(nlin)+' radial-hist[0-1,1-2,..,9+]: '+string(hist(1))+' '+string(hist(2))+' '+string(hist(3))+' '+string(hist(4))+' '+string(hist(5))+' '+string(hist(6))+' '+string(hist(7))+' '+string(hist(8))+' '+string(hist(9))+' '+string(hist(10)))
end
[diag]
[io.out('DIAG-GRP-DONE')]
program quit
