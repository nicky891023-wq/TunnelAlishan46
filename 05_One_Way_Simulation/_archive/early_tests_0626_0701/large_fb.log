flac3d>; --- QA functions DEFINED EARLY (parse-time catches FISH errors before the long solve) ---
flac3d>fish define qa_tension(tag)
   Def>    local maxprin = -1e30
   Def>    local nten = 0
   Def>    loop foreach local z zone.list
   Def>        local pz = zone.stress.prin.z(z)   ; max principal (least compressive / most tensile)
   Def>        if pz > maxprin then
   Def>            maxprin = pz
   Def>        end_if
   Def>        if pz > 1000.0 then
   Def>            nten = nten + 1
   Def>        end_if
   Def>    end_loop
   Def>    io.out('LFB-TENSION '+tag+' max_principal='+string(maxprin)+'Pa  tension_zones(prin>1kPa)='+string(nten)+'/'+string(zone.num))
   Def>end
flac3d>fish define qa_full(tag)
   Def>    local nplas = 0
   Def>    local mv = 0.0
   Def>    local mdsp = 0.0
   Def>    loop foreach local z zone.list
   Def>        if zone.state(z,1) # 0 then
   Def>            nplas = nplas + 1
   Def>        end_if
   Def>    end_loop
   Def>    loop foreach local g gp.list
   Def>        local v = gp.vel(g)
   Def>        local m = math.sqrt(comp.x(v)*comp.x(v)+comp.y(v)*comp.y(v)+comp.z(v)*comp.z(v))
   Def>        if m > mv then
   Def>            mv = m
   Def>        end_if
   Def>        local d = gp.disp(g)
   Def>        local md = math.sqrt(comp.x(d)*comp.x(d)+comp.y(d)*comp.y(d)+comp.z(d)*comp.z(d))
   Def>        if md > mdsp then
   Def>            mdsp = md
   Def>        end_if
   Def>    end_loop
   Def>    io.out('LFB-FULL '+tag+' plastic_zones='+string(nplas)+'/'+string(zone.num)+' max_gp_vel='+string(mv)+' max_gp_disp='+string(mdsp*1000.0)+'mm')
   Def>end
