flac3d>; Unification rulings (Wade):
flac3d>;   * nu = 0.25 single value (static MC + creep bulk same source).
flac3d>;   * E is PER-LAYER (not uniform): lithology-based within Hoek-Diederichs
flac3d>;     rock-mass range (sandstone 3-8, sandshale 1-3 GPa; colluvium/weathered soft).
flac3d>;     -> GSI/E have NO field data: per-layer E are documented-range central
flac3d>;        judgements, GSI-basis TODO (D3). c/phi are GSI-reduced placeholders.
flac3d>;   * Burgers creep: shear-maxwell = shear-kelvin = the layer ELASTIC G,
flac3d>;     bulk = the layer elastic K  (instantaneous static==creep, no spurious soften).
flac3d>;   * viscosity-maxwell eta_m = 6.0e15 Pa.s ; viscosity-kelvin eta_k = 2.4e13 Pa.s.
flac3d>;   * creep threshold ratio = 0.6 :  q_th = 0.6*(c*cos(phi)+p'*sin(phi)).
flac3d>;   * creep timestep = 600 s (fixed).
flac3d>;   * layer4 sandshale(WET): c = 100 kPa, phi = 30 deg (Wade).
flac3d>; Units: SI (Pa, kg/m3, deg, m, Pa.s).  Sign: compression negative.
flac3d>; ============================================================================
flac3d>
flac3d>; ---------- global / environment ----------
flac3d>[global nu     = 0.25]            ; single Poisson, all rock layers
flac3d>[global K0     = 0.7]             ; lateral stress ratio (placeholder, no field basis)
flac3d>[global grav   = 9.81]            ; m/s2
flac3d>[global poro   = 0.1]             ; porosity n
flac3d>[global satr   = 0.1]             ; saturation S
flac3d>[global rho_w  = 1000.0]          ; water density kg/m3
flac3d>[global pmb    = 1.0e-5]          ; FLAC mobility coeff m2/(Pa.s); near-tunnel x100
flac3d>[global ten_r  = 1.0e5]           ; rock tension cutoff 100 kPa (all layers)
flac3d>
flac3d>; ---------- elastic helpers (nu=0.25 -> G=E/2.5, K=E/1.5) ----------
flac3d>fish define _gk(ee)
   Def>    _gk = ee / (2.0*(1.0+nu))     ; shear  G
   Def>end
flac3d>fish define _bk(ee)
   Def>    _bk = ee / (3.0*(1.0-2.0*nu)) ; bulk   K
   Def>end
