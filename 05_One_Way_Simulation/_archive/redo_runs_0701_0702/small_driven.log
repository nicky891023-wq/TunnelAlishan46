flac3d>; ----------------------------------------------------------------------------
flac3d>; 6) LOAD THE LARGE-DRIVEN BOX-FACE TARGETS (small_drive.txt, from small_idw.py).
flac3d>;    Per-stage CUMULATIVE displacement -> gp.extra(g,1..4); tag 'driven' slot 'drive';
flac3d>;    FIX their velocity so the solver cannot overwrite the imposed motion.
flac3d>;    Pattern: couple_drive.f3dat load_targets L55-82 (here: 'id d1x..d4z').
flac3d>; ----------------------------------------------------------------------------
flac3d>fish define load_targets
   Def>    local lines = array.create(60000)
   Def>    local st = file.open('small_drive_residual.txt',0,1)   ; DEFORMATIONAL residual (rigid translation+rotation removed): the box's pure strain field = the true tunnel-squeezing drive (FULL field is ~99% rigid translation, which does not deform the tunnel)
   Def>    local nn = file.read(lines, 60000)
   Def>    st = file.close
   Def>    global ndriven = 0
   Def>    global nmiss = 0
   Def>    local i = 2                                          ; skip header line 1
   Def>    loop while i <= nn
   Def>        local gid = int(string.token(lines(i),1))
   Def>        local g = gp.find(gid)
   Def>        if g = null then
   Def>            nmiss = nmiss + 1
   Def>        else
   Def>            gp.extra(g,1) = vector(string.token(lines(i),2),string.token(lines(i),3),string.token(lines(i),4))
   Def>            gp.extra(g,2) = vector(string.token(lines(i),5),string.token(lines(i),6),string.token(lines(i),7))
   Def>            gp.extra(g,3) = vector(string.token(lines(i),8),string.token(lines(i),9),string.token(lines(i),10))
   Def>            gp.extra(g,4) = vector(string.token(lines(i),11),string.token(lines(i),12),string.token(lines(i),13))
   Def>            gp.group(g,'drive') = 'driven'
   Def>            ndriven = ndriven + 1
   Def>        end_if
   Def>        i = i + 1
   Def>    end_loop
   Def>    io.out('SD-LT driven='+string(ndriven)+' miss='+string(nmiss))
   Def>    load_targets = ndriven
   Def>end
