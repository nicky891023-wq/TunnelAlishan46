flac3d>; ----------------------------------------------------------------------------
flac3d>; 3) THRESHOLD-GATED CREEP (corrected MC envelope; rock only).
flac3d>;    q_th = 0.6*(c*cos(phi) + p'*sin(phi))  -- s4_rerun_convhist.f3dat L32-58.
flac3d>;    NOT the old tan form (~15.5% over-trigger). p' = effective mean (pore subtracted).
flac3d>; ----------------------------------------------------------------------------
flac3d>[global threhold = 0.6]
flac3d>fish define do_threshold
   Def>    local na = 0
   Def>    loop foreach local z zone.list
   Def>        if zone.group(z,'mat') = 'rock' then
   Def>            local s1 = -zone.stress.prin.x(z)
   Def>            local s3 = -zone.stress.prin.z(z)
   Def>            local pore = zone.pp(z)
   Def>            local pmean = (s1 + s3)/2.0 - pore
   Def>            local q = (s1 - s3)/2.0
   Def>            local c = zone.prop(z,'cohesion')
   Def>            local phi = zone.prop(z,'friction')
   Def>            local q_th = threhold*(c*math.cos(phi*math.degrad) + pmean*math.sin(phi*math.degrad))   ; corrected MC envelope (parameter.f3dat L14)
   Def>            if q >= q_th then
   Def>                zone.prop(z,'viscosity-kelvin')  = eta_k
   Def>                zone.prop(z,'viscosity-maxwell') = eta_m
   Def>                zone.group(z,'creep') = 'CreepActive'
   Def>                na = na + 1
   Def>            else
   Def>                zone.prop(z,'viscosity-kelvin')  = 1e100
   Def>                zone.prop(z,'viscosity-maxwell') = 1e100
   Def>                zone.group(z,'creep') = 'CreepOff'
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    global n_active = na
   Def>end
flac3d>
flac3d>; ----------------------------------------------------------------------------
flac3d>; 4) SHELL E-REDUCTION-ON-YIELD DAMAGE (two-cap, monotonic, stress-capped).
flac3d>;    demand = max(sigma_c/fc, sigma_t/ft); E_new = E_old/demand with floor 2.5 GPa,
flac3d>;    max 50% drop/event, eps 1% chatter guard, MONOTONIC. SHELL_LINING_recipe.md
flac3d>;    STEP 3 (verbatim). Caps fc=41.2 MPa / ft=4.12 MPa (parameter.f3dat L95-96).
flac3d>;    Called at creep-segment boundaries (NOT per-cycle on 1.4M zones).
flac3d>; ----------------------------------------------------------------------------
flac3d>[global sigCap_c = shot_fc]        ; 41.2e6 compression cap
flac3d>[global sigCap_t = shot_ft]        ; 4.12e6 tension cap
flac3d>[global E_floor  = 2.5e9]          ; residual cracked-RC modulus floor
flac3d>[global drop_max = 0.5]            ; <=50% E reduction per event
flac3d>[global dmg_eps  = 0.01]           ; 1% over-cap tolerance (anti-chatter)
flac3d>; RECORD-ONLY (E-reduction is force-controlled here -- cannot cap shell stress;
flac3d>; verified by test_shell_E_command/smoke_shell_damage: set-E drops stress only
flac3d>; pre-solve, the strain compensates on re-solve back to force/area. So the shell
flac3d>; stays E0 (bounds convergence; drive supplies the ~10-20cm magnitude) and we RECORD
flac3d>; the over-stressed (cracking) shells as the lining CRACK PATTERN. n_shell_red = the
flac3d>; count of shells over the tension cap (4.12MPa) or compression cap (41.2MPa).
flac3d>fish define shell_damage
   Def>    command
   Def>        structure shell recover surface (0,1,0)
   Def>        structure shell recover stress depth-factor 0
   Def>    endcommand
   Def>    local ncrk_t = 0
   Def>    local ncrk_c = 0
   Def>    local maxt = 0.0
   Def>    local maxc = 0.0
   Def>    loop foreach local s struct.list
   Def>        if struct.type(s) = 'shell' then
   Def>            local sc = 0.0
   Def>            local st = 0.0
   Def>            loop local k (0,3)
   Def>                local smin = struct.shell.stress.prin.x(s,k)   ; min principal (most compressive, signed)
   Def>                if -smin > sc then
   Def>                    sc = -smin
   Def>                end_if
   Def>                local smax = struct.shell.stress.prin.z(s,k)   ; max principal (most tensile, signed)
   Def>                if smax > st then
   Def>                    st = smax
   Def>                end_if
   Def>            end_loop
   Def>            if st > sigCap_t then
   Def>                ncrk_t = ncrk_t + 1
   Def>            end_if
   Def>            if sc > sigCap_c then
   Def>                ncrk_c = ncrk_c + 1
   Def>            end_if
   Def>            if st > maxt then
   Def>                maxt = st
   Def>            end_if
   Def>            if sc > maxc then
   Def>                maxc = sc
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    global n_shell_red = ncrk_t + ncrk_c     ; cracking-shell count (tension OR compression over cap)
   Def>    global n_crk_tension = ncrk_t
   Def>    global n_crk_compress = ncrk_c
   Def>    global shell_maxt = maxt
   Def>    global shell_maxc = maxc
   Def>end
