flac3d>; ----------------------------------------------------------------------------
flac3d>; 7) DRIVE_AND_CREEP(stg, nsub, ncyc_sub, d0, d1, dd) -- one full stage.
flac3d>;    (1) per-gp increment to this stage's cumulative target gp.extra(g,stg)
flac3d>;    (2) sub-step velocity ramp + model calm (mechanical, creep off)
flac3d>;    (3) hold (vel=0), re-equilibrate in burgers-mohr stiffness (ratio-average,
flac3d>;        NOT elastic -- Wade rule #3); setKstrains; do_threshold; setKstrains;
flac3d>;        shell_damage (post-drive, pre-creep)
flac3d>;    (4) threshold-gated creep over the stage days (crp_dt fixed timestep),
flac3d>;        shell_damage at each dd-day creep-segment boundary
flac3d>;    Pattern: couple_drive.f3dat run_stage L84-116 + SHELL_LINING_recipe.md STEP 4b.
flac3d>;    NOTE: funcs called bare INSIDE a define (setKstrains/do_threshold/shell_damage)
flac3d>;    are plain FISH calls -- valid; only TOP-LEVEL invocation needs [..] (lesson #74).
flac3d>; ----------------------------------------------------------------------------
flac3d>fish define drive_and_creep(stg, nsub, ncyc_sub, d0, d1, dd)
   Def>    ; (1) increment per driven gp = stage cumulative target - current disp
   Def>    loop foreach local g gp.list
   Def>        if gp.group(g,'drive') = 'driven' then
   Def>            gp.extra(g,5) = gp.extra(g, stg) - gp.disp(g)
   Def>        end_if
   Def>    end_loop
   Def>    local denom = float(nsub) * float(ncyc_sub) * mech.timestep
   Def>    ; (2) sub-step ramp (mechanical cycles, creep already off here)
   Def>    local j = 1
   Def>    loop while j <= nsub
   Def>        loop foreach local g2 gp.list
   Def>            if gp.group(g2,'drive') = 'driven' then
   Def>                gp.vel(g2) = gp.extra(g2,5) / denom
   Def>            end_if
   Def>        end_loop
   Def>        command
   Def>            model cycle [ncyc_sub]
   Def>            model calm
   Def>        endcommand
   Def>        io.out('   SD-sub stg'+string(stg)+' j='+string(j)+'/'+string(nsub)+' dmax='+string(dmax_all))
   Def>        j = j + 1
   Def>    end_loop
   Def>    ; (3) hold target, re-equilibrate rock in burgers-mohr stiffness
   Def>    loop foreach local g3 gp.list
   Def>        if gp.group(g3,'drive') = 'driven' then
   Def>            gp.vel(g3) = vector(0,0,0)
   Def>        end_if
   Def>    end_loop
   Def>    command
   Def>        model solve ratio-average 1e-5 cycles 40000
   Def>    endcommand
   Def>    setKstrains                                  ; re-set Kelvin strain to NEW post-drive stress (FLAC creep gotcha; prototype L96)
   Def>    do_threshold                                 ; gate creep on the boundary-squeezed stress state
   Def>    setKstrains                                  ; re-set again after viscosity flip
   Def>    shell_damage                                 ; update shell E post-drive, pre-creep
   Def>    io.out('   SD-stg'+string(stg)+' post-drive eq: active='+string(n_active)+' shell_reduced='+string(n_shell_red)+' dmax='+string(dmax_all))
   Def>    ; (4) threshold-gated creep over the stage days
   Def>    command
   Def>        model creep active on
   Def>        model creep timestep fix [crp_dt]
   Def>    endcommand
   Def>    local d = d0 + dd
   Def>    loop while d <= (d1 + 0.1)
   Def>        do_threshold                             ; per-increment threshold (multi-thread safe; NOT per-cycle)
   Def>        global cur_day = d
   Def>        command
   Def>            model solve time-total [d*86400.0]
   Def>        endcommand
   Def>        shell_damage                             ; recover shell stress + count cracking shells at the creep-segment boundary
   Def>        io.out('   SD-creep stg'+string(stg)+' day='+string(d)+' vclose='+string(vclose)+'mm hclose='+string(hclose)+'mm dmax='+string(dmax_all)+' active='+string(n_active)+' crk(t/c)='+string(n_crk_tension)+'/'+string(n_crk_compress)+' shellMaxT='+string(shell_maxt/1e6)+'MPa')
   Def>        d = d + dd
   Def>    end_loop
   Def>    command
   Def>        model creep active off
   Def>        zone gridpoint initialize velocity 0 0 0   ; zero ONLY velocity between stages (Wade rule #2; disp stays cumulative)
   Def>    endcommand
   Def>end
