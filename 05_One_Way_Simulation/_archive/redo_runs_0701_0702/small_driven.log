flac3d>; ----------------------------------------------------------------------------
flac3d>; 5) Y860-910 CROWN/SIDEWALL CONVERGENCE (diameter closure, in-situ day-0 datum).
flac3d>;    s4_rerun_convhist.f3dat L60-205 (verbatim). vclose/hclose = sentinel y885
flac3d>;    continuous histories; band_conv = y860-910 band average for J/C. NEGATIVE =
flac3d>;    closing. NOT zeroed at day 0 -- datum is the in-situ displacement.
flac3d>; ----------------------------------------------------------------------------
flac3d>fish define find_conv_gps
   Def>    global g_crown = null
   Def>    global g_invert = null
   Def>    global g_sprR = null
   Def>    global g_sprL = null
   Def>    local bc = 1e20
   Def>    local bi = 1e20
   Def>    local br = 1e20
   Def>    local bl = 1e20
   Def>    loop foreach local g gp.list
   Def>        local p = gp.pos(g)
   Def>        local yy = comp.y(p)
   Def>        if yy > 884.0 then
   Def>        if yy < 886.0 then
   Def>            local dcr = (comp.x(p)-1297.0)*(comp.x(p)-1297.0)+(comp.z(p)-1752.0)*(comp.z(p)-1752.0)
   Def>            if dcr < bc then
   Def>                bc = dcr
   Def>                g_crown = g
   Def>            end_if
   Def>            local din = (comp.x(p)-1297.0)*(comp.x(p)-1297.0)+(comp.z(p)-1743.0)*(comp.z(p)-1743.0)
   Def>            if din < bi then
   Def>                bi = din
   Def>                g_invert = g
   Def>            end_if
   Def>            local dsr = (comp.x(p)-1303.0)*(comp.x(p)-1303.0)+(comp.z(p)-1747.0)*(comp.z(p)-1747.0)
   Def>            if dsr < br then
   Def>                br = dsr
   Def>                g_sprR = g
   Def>            end_if
   Def>            local dsl = (comp.x(p)-1291.0)*(comp.x(p)-1291.0)+(comp.z(p)-1747.0)*(comp.z(p)-1747.0)
   Def>            if dsl < bl then
   Def>                bl = dsl
   Def>                g_sprL = g
   Def>            end_if
   Def>        end_if
   Def>        end_if
   Def>    end_loop
   Def>    io.out('CONV-GPS crown_dist='+string(math.sqrt(bc))+' invert_dist='+string(math.sqrt(bi))+' sprR_dist='+string(math.sqrt(br))+' sprL_dist='+string(math.sqrt(bl)))
   Def>end
flac3d>fish define vclose
   Def>    vclose = (comp.z(gp.disp(g_crown)) - comp.z(gp.disp(g_invert)))*1000.0
   Def>end
flac3d>fish define hclose
   Def>    hclose = (comp.x(gp.disp(g_sprR)) - comp.x(gp.disp(g_sprL)))*1000.0
   Def>end
flac3d>fish define report_conv(tag)
   Def>    io.out('CONV '+tag+' vert_closure='+string(vclose)+'mm horiz_closure='+string(hclose)+'mm | crown_dz='+string(comp.z(gp.disp(g_crown))*1000.0)+' invert_dz='+string(comp.z(gp.disp(g_invert))*1000.0)+' sprR_dx='+string(comp.x(gp.disp(g_sprR))*1000.0)+' sprL_dx='+string(comp.x(gp.disp(g_sprL))*1000.0))
   Def>end
flac3d>fish define band_conv(tag)
   Def>    local scr = 0.0
   Def>    local ncr = 0
   Def>    local mxcr = -1e20
   Def>    local mncr = 1e20
   Def>    local sin = 0.0
   Def>    local nin = 0
   Def>    local mxin = -1e20
   Def>    local mnin = 1e20
   Def>    local ssr = 0.0
   Def>    local nsr = 0
   Def>    local ssl = 0.0
   Def>    local nsl = 0
   Def>    loop foreach local g gp.list
   Def>        local p = gp.pos(g)
   Def>        local yy = comp.y(p)
   Def>        if yy >= 860.0 then
   Def>        if yy <= 910.0 then
   Def>            local rx = comp.x(p)-1297.0
   Def>            local rz = comp.z(p)-1747.5
   Def>            local rr = math.sqrt(rx*rx+rz*rz)
   Def>            if rr >= 4.5 then
   Def>            if rr <= 5.5 then
   Def>                local ang = math.atan2(rz,rx)/math.degrad
   Def>                if ang < 0.0 then
   Def>                    ang = 360.0+ang
   Def>                end_if
   Def>                local d = gp.disp(g)
   Def>                local dzv = comp.z(d)
   Def>                local dxv = comp.x(d)
   Def>                if ang >= 75.0 then
   Def>                if ang <= 105.0 then
   Def>                    scr = scr + dzv
   Def>                    ncr = ncr + 1
   Def>                    if dzv > mxcr then
   Def>                        mxcr = dzv
   Def>                    end_if
   Def>                    if dzv < mncr then
   Def>                        mncr = dzv
   Def>                    end_if
   Def>                end_if
   Def>                end_if
   Def>                if ang >= 255.0 then
   Def>                if ang <= 285.0 then
   Def>                    sin = sin + dzv
   Def>                    nin = nin + 1
   Def>                    if dzv > mxin then
   Def>                        mxin = dzv
   Def>                    end_if
   Def>                    if dzv < mnin then
   Def>                        mnin = dzv
   Def>                    end_if
   Def>                end_if
   Def>                end_if
   Def>                if ang >= 345.0 then
   Def>                    ssr = ssr + dxv
   Def>                    nsr = nsr + 1
   Def>                end_if
   Def>                if ang <= 15.0 then
   Def>                    ssr = ssr + dxv
   Def>                    nsr = nsr + 1
   Def>                end_if
   Def>                if ang >= 165.0 then
   Def>                if ang <= 195.0 then
   Def>                    ssl = ssl + dxv
   Def>                    nsl = nsl + 1
   Def>                end_if
   Def>                end_if
   Def>            end_if
   Def>            end_if
   Def>        end_if
   Def>        end_if
   Def>    end_loop
   Def>    local mcr = 0.0
   Def>    if ncr > 0 then
   Def>        mcr = scr/float(ncr)
   Def>    end_if
   Def>    local mvin = 0.0
   Def>    if nin > 0 then
   Def>        mvin = sin/float(nin)
   Def>    end_if
   Def>    local msr = 0.0
   Def>    if nsr > 0 then
   Def>        msr = ssr/float(nsr)
   Def>    end_if
   Def>    local msl = 0.0
   Def>    if nsl > 0 then
   Def>        msl = ssl/float(nsl)
   Def>    end_if
   Def>    local vert = (mcr - mvin)*1000.0
   Def>    local horiz = (msr - msl)*1000.0
   Def>    global band_vert = vert
   Def>    global band_horiz = horiz
   Def>    io.out('BAND-CONV '+tag+' vert_closure='+string(vert)+'mm horiz_closure='+string(horiz)+'mm | crown_dz mean='+string(mcr*1000.0)+' [min'+string(mncr*1000.0)+',max'+string(mxcr*1000.0)+'] invert_dz mean='+string(mvin*1000.0)+' [min'+string(mnin*1000.0)+',max'+string(mxin*1000.0)+'] | n(cr/in/sr/sl)='+string(ncr)+'/'+string(nin)+'/'+string(nsr)+'/'+string(nsl))
   Def>end
