flac3d>
flac3d>; --- per-stage: fluid(500cyc) -> MC 1e-5 -> creep in 2.5-day segments + shell cap between ---
flac3d>fish define crp_stage(stg, wtname, fname, days)
   Def>    if abort_flag = 1 then
   Def>        io.out('SSv2-SKIP stage '+string(stg)+' (abort flag set)')
   Def>    else
   Def>    command
   Def>        zone cmodel assign mohr-coulomb range group 'rock' slot 'mat'
   Def>        zone property young [E_S_1] poisson [nu] cohesion [co_S_1] friction [fr_S_1] tension [ten_r] range group 'layer1' slot 'type'
   Def>        zone property young [E_S_2] poisson [nu] cohesion [co_S_2] friction [fr_S_2] tension [ten_r] range group 'layer2' slot 'type'
   Def>        zone property young [E_S_3] poisson [nu] cohesion [co_S_3] friction [fr_S_3] tension [ten_r] range group 'layer3' slot 'type'
   Def>        zone property young [E_S_4] poisson [nu] cohesion [co_S_4] friction [fr_S_4] tension [ten_r] range group 'layer4' slot 'type'
   Def>        zone property young [E_S_5] poisson [nu] cohesion [co_S_5] friction [fr_S_5] tension [ten_r] range group 'layer5' slot 'type'
   Def>        zone property young [E_S_6] poisson [nu] cohesion [co_S_6] friction [fr_S_6] tension [ten_r] range group 'layer6' slot 'type'
   Def>        zone gridpoint initialize pore-pressure 0
   Def>        zone water set [wtname]
   Def>        zone gridpoint initialize saturation 1
   Def>        zone gridpoint initialize saturation 0 range geometry-space [wtname] count 0 direction (0,0,1)
   Def>        zone gridpoint initialize pore-pressure 0 range geometry-distance 'tunnel_inner' gap 1.0
   Def>        zone gridpoint fix pore-pressure range group 'East' or 'West' or 'North' or 'South' or 'Top' or 'Bottom'
   Def>        model mechanical active off
   Def>        model creep active off
   Def>        model fluid active on
   Def>        model solve ratio-flow 1e-4 or cycles 500
   Def>    endcommand
   Def>    io.out('   SSv2-stg'+string(stg)+' '+wtname+' fluid phase done (500cyc budget)')
   Def>    command
   Def>        model fluid active off
   Def>        model mechanical active on
   Def>        model creep active off
   Def>        zone gridpoint initialize fluid-modulus 0
   Def>        zone gridpoint initialize velocity 0 0 0
   Def>        model solve ratio 1e-5 or cycles 40000
   Def>    endcommand
   Def>    io.out('   SSv2-stg'+string(stg)+' MC balance done')
   Def>    command
   Def>        zone cmodel assign burgers-mohr range group 'rock' slot 'mat'
   Def>        ; NOTE: cmodel assign RESETS all properties -> strength MUST be re-set here
   Def>        ; (OPUS port dropped cohesion/friction/tension -> c=phi=0 -> q_th=0 -> 100% active
   Def>        ;  + zero-strength plastic collapse = the real 07-02 runaway root cause).
   Def>        zone property bulk [_bk(E_S_1)] shear-maxwell [_gk(E_S_1)] shear-kelvin [_gk(E_S_1)] viscosity-kelvin [eta_k] cohesion [co_S_1] friction [fr_S_1] tension [ten_r] range group 'layer1' slot 'type'
   Def>        zone property bulk [_bk(E_S_2)] shear-maxwell [_gk(E_S_2)] shear-kelvin [_gk(E_S_2)] viscosity-kelvin [eta_k] cohesion [co_S_2] friction [fr_S_2] tension [ten_r] range group 'layer2' slot 'type'
   Def>        zone property bulk [_bk(E_S_3)] shear-maxwell [_gk(E_S_3)] shear-kelvin [_gk(E_S_3)] viscosity-kelvin [eta_k] cohesion [co_S_3] friction [fr_S_3] tension [ten_r] range group 'layer3' slot 'type'
   Def>        zone property bulk [_bk(E_S_4)] shear-maxwell [_gk(E_S_4)] shear-kelvin [_gk(E_S_4)] viscosity-kelvin [eta_k] cohesion [co_S_4] friction [fr_S_4] tension [ten_r] range group 'layer4' slot 'type'
   Def>        zone property bulk [_bk(E_S_5)] shear-maxwell [_gk(E_S_5)] shear-kelvin [_gk(E_S_5)] viscosity-kelvin [eta_k] cohesion [co_S_5] friction [fr_S_5] tension [ten_r] range group 'layer5' slot 'type'
   Def>        zone property bulk [_bk(E_S_6)] shear-maxwell [_gk(E_S_6)] shear-kelvin [_gk(E_S_6)] viscosity-kelvin [eta_k] cohesion [co_S_6] friction [fr_S_6] tension [ten_r] range group 'layer6' slot 'type'
   Def>        model creep active on
   Def>    endcommand
   Def>    read_drive(fname)
   Def>    setKstrains
   Def>    do_threshold
   Def>    setKstrains
   Def>    apply_vel_idw(days*86400.0, 60.0)
   Def>    io.out('   SSv2-stg'+string(stg)+' creep start: active='+string(n_active))
   Def>    local nch = math.ceiling(days/1.25)
   Def>    local dch = days/nch
   Def>    local ich = 0
   Def>    loop while ich < nch
   Def>        ich = ich + 1
   Def>        cum_days = cum_days + dch
   Def>        command
   Def>            model creep timestep fix [crp_dt]
   Def>            model solve creep time-total [cum_days*86400.0]
   Def>        endcommand
   Def>        shell_cap
   Def>        io.out('SSv2-HIST stg='+string(stg)+' day='+string(cum_days)+' vclose='+string(vclose)+' hclose='+string(hclose)+' dmax='+string(dmax_all)+' active='+string(n_active)+' ncap='+string(n_capped)+' novf='+string(n_overfloor)+' maxC='+string(sh_maxc/1e6)+'MPa maxT='+string(sh_maxt/1e6)+'MPa')
   Def>        if dmax_all > 0.20 then
   Def>            abort_flag = 1
   Def>            ich = nch
   Def>            io.out('SSv2-ABORT kinematic runaway dmax>0.2m (stg '+string(stg)+')')
   Def>        end_if
   Def>    end_loop
   Def>    io.out('SSv2-CHK stg'+string(stg)+' END vclose='+string(vclose)+'mm hclose='+string(hclose)+'mm dmax='+string(dmax_all)+' active='+string(n_active)+' maxC='+string(sh_maxc/1e6)+' maxT='+string(sh_maxt/1e6))
   Def>    end_if
   Def>end
