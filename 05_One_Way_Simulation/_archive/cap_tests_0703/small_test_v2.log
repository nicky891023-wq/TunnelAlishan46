flac3d>fish define shell_cap
   Def>    command
   Def>        structure shell recover surface (0,1,0)
   Def>        structure shell recover stress depth-factor 0
   Def>    endcommand
   Def>    global n_capped = 0
   Def>    global n_overfloor = 0
   Def>    global sh_maxc = 0.0
   Def>    global sh_maxt = 0.0
   Def>    loop foreach local s struct.list
   Def>        if struct.type(s) = 'shell' then
   Def>            local smn = 1e30
   Def>            local smx = -1e30
   Def>            loop local k (0,3)
   Def>                local sx = struct.shell.stress.prin.x(s,k)
   Def>                local sz = struct.shell.stress.prin.z(s,k)
   Def>                if sx < smn then
   Def>                    smn = sx
   Def>                end_if
   Def>                if sz > smx then
   Def>                    smx = sz
   Def>                end_if
   Def>            end_loop
   Def>            local sc = 0.0
   Def>            if smn < 0.0 then
   Def>                sc = -smn
   Def>            end_if
   Def>            local stn = 0.0
   Def>            if smx > 0.0 then
   Def>                stn = smx
   Def>            end_if
   Def>            if sc > sh_maxc then
   Def>                sh_maxc = sc
   Def>            end_if
   Def>            if stn > sh_maxt then
   Def>                sh_maxt = stn
   Def>            end_if
   Def>            local scale = 1.0
   Def>            if sc > (1.0+sig_eps)*sig_capC then
   Def>                scale = sig_capC/sc
   Def>            end_if
   Def>            if stn > (1.0+sig_eps)*sig_capT then
   Def>                if sig_capT/stn < scale then
   Def>                    scale = sig_capT/stn
   Def>                end_if
   Def>            end_if
   Def>            if scale < 1.0 then
   Def>                local en = struct.shell.young(s)
   Def>                local et = en*scale
   Def>                if et < e_floor then
   Def>                    et = e_floor
   Def>                end_if
   Def>                if et < en then
   Def>                    struct.shell.young(s) = et
   Def>                    n_capped = n_capped + 1
   Def>                end_if
   Def>                ; gross overshoot on a shell that still had reducible stiffness =
   Def>                ; the cap mechanism itself is lagging (floor-bound residual ~2x ft is
   Def>                ; accepted physics: fully-cracked RC at E_floor under imposed strain)
   Def>                if en > 1.05*e_floor then
   Def>                    local gross = 0
   Def>                    if sc > 2.0*sig_capC then
   Def>                        gross = 1
   Def>                    end_if
   Def>                    if stn > 2.0*sig_capT then
   Def>                        gross = 1
   Def>                    end_if
   Def>                    n_overfloor = n_overfloor + gross
   Def>                end_if
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    local uu = struct.force.update()
   Def>end
