flac3d>fish define mid_wall_force(pfx, y0, y1)
   Def>    global fmid_sum = 0.0      ; signed sum of normal force (compression>0 per PFC convention varies)
   Def>    global fmid_abs = 0.0      ; sum |normal force| = contact-load magnitude proxy
   Def>    global nmid_c = 0
   Def>    ; coupling (ball-facet on wz_outter) = linearpbond unbreakable pb_ten>=1e10 (cb_control0 has NO
