   Def>        local p = contact.pos(c)
   Def>        local f = contact.force.global(c)
   Def>        a(1) = string(comp.x(p))+' '+string(comp.y(p))+' '+string(comp.z(p))+' '+string(comp.x(f))+' '+string(comp.y(f))+' '+string(comp.z(f))
   Def>        st = file.write(a,1)
   Def>        n = n + 1
   Def>    end_loop
   Def>    st = file.close
   Def>    io.out('EXPPF '+fname+' n='+string(n))
   Def>end
