flac3d>; --- export small-model-box gridpoint displacement (x y z dx dy dz) ---
flac3d>fish define export_box_disp(fname)
   Def>    local st = file.open(fname,1,1)
   Def>    local fl = array.create(1)
   Def>    fl(1) = 'x y z dx dy dz'
   Def>    st = file.write(fl,1)
   Def>    local nout = 0
   Def>    loop foreach local g gp.list
   Def>        local p = gp.pos(g)
   Def>        local x = comp.x(p)
   Def>        if x > 1245.0 then
   Def>        if x < 1355.0 then
   Def>            local y = comp.y(p)
   Def>            if y > 845.0 then
   Def>            if y < 955.0 then
   Def>                local zz = comp.z(p)
   Def>                if zz > 1695.0 then
   Def>                if zz < 1805.0 then
   Def>                    local d = gp.disp(g)
   Def>                    fl(1) = string(x)+' '+string(y)+' '+string(zz)+' '+string(comp.x(d))+' '+string(comp.y(d))+' '+string(comp.z(d))
   Def>                    st = file.write(fl,1)
   Def>                    nout = nout + 1
   Def>                end_if
   Def>                end_if
   Def>            end_if
   Def>            end_if
   Def>        end_if
   Def>        end_if
   Def>    end_loop
   Def>    st = file.close
   Def>    io.out('   LS-export '+fname+' box gps='+string(nout))
   Def>end
