flac3d>
flac3d>; --- threshold: Maxwell-only gating (Kelvin always on), 260529 corrected MC envelope ---
flac3d>fish define do_threshold
   Def>    local na = 0
   Def>    loop foreach local z zone.list
   Def>        if zone.model(z) # 'null' then          ; large model = all rock (no 'rock' group)
   Def>            local s1 = -zone.stress.prin.x(z)
   Def>            local s3 = -zone.stress.prin.z(z)
   Def>            local pore = zone.pp(z)
   Def>            local pmean = (s1 + s3)/2.0 - pore
   Def>            local q = (s1 - s3)/2.0
   Def>            local c = zone.prop(z,'cohesion')
   Def>            local phi = zone.prop(z,'friction')
   Def>            local q_th = crp_threshold*(c*math.cos(phi*math.degrad) + pmean*math.sin(phi*math.degrad))
   Def>            if q >= q_th then
   Def>                zone.prop(z,'viscosity-maxwell') = eta_m
   Def>                na = na + 1
   Def>            else
   Def>                zone.prop(z,'viscosity-maxwell') = 1e100
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    global n_active = na
   Def>end
flac3d>fish define dmax_all
   Def>    local dm = 0.0
   Def>    loop foreach local g gp.list
   Def>        local d = gp.disp(g)
   Def>        local m = math.sqrt(comp.x(d)^2+comp.y(d)^2+comp.z(d)^2)
   Def>        if m > dm then
   Def>            dm = m
   Def>        end_if
   Def>    end_loop
   Def>    dmax_all = dm
   Def>end
