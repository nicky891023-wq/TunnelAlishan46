flac3d>; --- per-stage three-phase process (fluid steady-state -> MC ratio 1e-5 -> creep) ---
flac3d>fish define crp_stage(stg, wtname, days)
   Def>    command
   Def>        ; (phase 1) set new water table + re-init saturation/pp, MC material (all rock)
   Def>        zone cmodel assign mohr-coulomb
   Def>        zone property young [E_L_1] poisson [nu] cohesion [co_L_1] friction [fr_L_1] tension [ten_r] range group 'layer1' slot 'type'
   Def>        zone property young [E_L_2] poisson [nu] cohesion [co_L_2] friction [fr_L_2] tension [ten_r] range group 'layer2' slot 'type'
   Def>        zone property young [E_L_3] poisson [nu] cohesion [co_L_3] friction [fr_L_3] tension [ten_r] range group 'layer3' slot 'type'
   Def>        zone property young [E_L_4] poisson [nu] cohesion [co_L_4] friction [fr_L_4] tension [ten_r] range group 'layer4' slot 'type'
   Def>        zone gridpoint initialize pore-pressure 0
   Def>        zone water set [wtname]
   Def>        zone gridpoint initialize saturation 1
   Def>        zone gridpoint initialize saturation 0 range geometry-space [wtname] count 0 direction (0,0,1)
   Def>        zone gridpoint initialize pore-pressure 0 range group 'Top'
   Def>        zone gridpoint fix pore-pressure range group 'North' or 'South' or 'East' or 'West' or 'Top' or 'Bottom'
   Def>        ; (phase 1 solve) fluid steady-state
   Def>        model mechanical active off
   Def>        model creep active off
   Def>        model fluid active on
   Def>        model solve ratio-flow 1e-4 or cycles 20000
   Def>    endcommand
   Def>    io.out('   LS-stg'+string(stg)+' '+wtname+' fluid steady-state done')
   Def>    command
   Def>        ; (phase 2) fluid off -> MC force balance (solve ratio 1e-5)
   Def>        model fluid active off
   Def>        model mechanical active on
   Def>        model creep active off
   Def>        zone gridpoint initialize fluid-modulus 0
   Def>        zone gridpoint initialize velocity 0 0 0
   Def>        model solve ratio 1e-5 or cycles 40000
   Def>    endcommand
   Def>    io.out('   LS-stg'+string(stg)+' MC balance done (ratio 1e-5)')
   Def>    command
   Def>        ; (phase 3) burgers-mohr creep : G_m=G_k=_gk(E), eta_m gated, eta_k always on (all rock)
   Def>        zone cmodel assign burgers-mohr
   Def>        zone property bulk [_bk(E_L_1)] shear-maxwell [_gk(E_L_1)] shear-kelvin [_gk(E_L_1)] viscosity-maxwell 1e100 viscosity-kelvin [eta_k] cohesion [co_L_1] friction [fr_L_1] tension [ten_r] range group 'layer1' slot 'type'
   Def>        zone property bulk [_bk(E_L_2)] shear-maxwell [_gk(E_L_2)] shear-kelvin [_gk(E_L_2)] viscosity-maxwell 1e100 viscosity-kelvin [eta_k] cohesion [co_L_2] friction [fr_L_2] tension [ten_r] range group 'layer2' slot 'type'
   Def>        zone property bulk [_bk(E_L_3)] shear-maxwell [_gk(E_L_3)] shear-kelvin [_gk(E_L_3)] viscosity-maxwell 1e100 viscosity-kelvin [eta_k] cohesion [co_L_3] friction [fr_L_3] tension [ten_r] range group 'layer3' slot 'type'
   Def>        zone property bulk [_bk(E_L_4)] shear-maxwell [_gk(E_L_4)] shear-kelvin [_gk(E_L_4)] viscosity-maxwell 1e100 viscosity-kelvin [eta_k] cohesion [co_L_4] friction [fr_L_4] tension [ten_r] range group 'layer4' slot 'type'
   Def>        model creep active on
   Def>    endcommand
   Def>    setKstrains
   Def>    do_threshold
   Def>    setKstrains
   Def>    cum_days = cum_days + days
   Def>    command
   Def>        model creep timestep fix [crp_dt]
   Def>        model solve creep time-total [cum_days*86400.0]
   Def>    endcommand
   Def>    io.out('   LS-stg'+string(stg)+' creep done: active='+string(n_active)+' dmax='+string(dmax_all))
   Def>end
