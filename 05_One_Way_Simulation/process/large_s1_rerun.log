flac3d>fish define setKstrains
   Def>    local p_z = zone.head
   Def>    loop while p_z # null
   Def>        local iflag = 0
   Def>        if zone.model(p_z) = 'burgers' then
   Def>            iflag = 1
   Def>        endif
   Def>        if zone.model(p_z) = 'burgers-mohr' then
   Def>            iflag = 1
   Def>        endif
   Def>        if iflag = 1 then
   Def>            local kg2 = 2.0 * zone.prop(p_z, 'shear-kelvin')
   Def>            if kg2 > 0.0 then
   Def>                local sig0 = (zone.stress.xx(p_z) + zone.stress.yy(p_z) + zone.stress.zz(p_z))/3.0
   Def>                zone.prop(p_z,'strain-kelvin-xx') = (zone.stress.xx(p_z) - sig0) / kg2
   Def>                zone.prop(p_z,'strain-kelvin-yy') = (zone.stress.yy(p_z) - sig0) / kg2
   Def>                zone.prop(p_z,'strain-kelvin-zz') = (zone.stress.zz(p_z) - sig0) / kg2
   Def>                zone.prop(p_z,'strain-kelvin-xy') = zone.stress.xy(p_z) / kg2
   Def>                zone.prop(p_z,'strain-kelvin-xz') = zone.stress.xz(p_z) / kg2
   Def>                zone.prop(p_z,'strain-kelvin-yz') = zone.stress.yz(p_z) / kg2
   Def>            endif
   Def>        endif
   Def>        p_z = z.next(p_z)
   Def>    endloop
   Def>end
