[exp_wall('cpl_wall_s05.txt')]
[io.out('CEB stage 05 done')]
model restore '../output/ss_06'
[exp_bnd('cpl_bnd_s06.txt')]
[exp_wall('cpl_wall_s06.txt')]
[io.out('CEB stage 06 done')]
model restore '../output/ss_07'
