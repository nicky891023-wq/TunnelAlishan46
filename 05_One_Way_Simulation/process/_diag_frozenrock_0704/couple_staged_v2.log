flac3d>; mid-band only wz_outter reaction: integrate bf_couple ball-facet contact forces over y in [y0,y1]
flac3d>;   (total wall.force.contact is end-contaminated; this isolates the mid-tunnel lining reaction)
flac3d>fish define mid_wall_force(pfx, y0, y1)
   Def>    global fmid_sum = 0.0      ; signed sum of normal force (compression>0 per PFC convention varies)
   Def>    global fmid_abs = 0.0      ; sum |normal force| = contact-load magnitude proxy
   Def>    global nmid_c = 0
   Def>    ; coupling (ball-facet on wz_outter) = linearpbond unbreakable pb_ten>=1e10 (cb_control0 has NO
   Def>    ;   'bf_couple' group; identify by pb_ten instead verified 62556 coupling contacts, 47806 in mid)
   Def>    loop foreach local c contact.list
   Def>        if contact.model(c) = 'linearpbond' then
   Def>            if contact.prop(c,'pb_ten') >= 1.0e10 then
   Def>                local p = contact.pos(c)
   Def>                local yy = comp.y(p)
   Def>                if yy >= y0 then
   Def>                    if yy <= y1 then
   Def>                        local fn = contact.force.normal(c)
   Def>                        fmid_sum = fmid_sum + fn
   Def>                        local af = fn
   Def>                        if af < 0.0 then
   Def>                            af = -af
   Def>                        end_if
   Def>                        fmid_abs = fmid_abs + af
   Def>                        nmid_c = nmid_c + 1
   Def>                    end_if
   Def>                end_if
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>    io.out('MID-WALL '+pfx+' y['+string(y0)+','+string(y1)+'] bf_couple_n='+string(nmid_c)+' sum_normal='+string(fmid_sum/1e6)+'MN abs_normal='+string(fmid_abs/1e6)+'MN')
   Def>end
flac3d>; mid-band tunnel-wall convergence (Codex Q2 2nd proof): lining-ball radial-inward displacement in
flac3d>;   y[y0,y1]. ball.disp tracks drive-induced motion (datum reset zeroed it). reports mean/max + inner-band.
flac3d>fish define mid_convergence(pfx, y0, y1)
   Def>    local cx = 1297.0
   Def>    local cz = 1747.5
   Def>    ; INNER-WALL (r 1.35-2.0m) radial convergence, split by region (Codex): blue-line load region
   Def>    ;   (ang NOT in 250-320deg = sidewalls+crown) vs fixed-corner band (ang 250-320 = artifact).
   Def>    global cv_blue = 0.0
   Def>    global mx_blue = 0.0
   Def>    global nb_blue = 0
   Def>    global cv_corner = 0.0
   Def>    global mx_corner = 0.0
   Def>    global nb_corner = 0
   Def>    local sblue = 0.0
   Def>    local scorner = 0.0
   Def>    loop foreach local b ball.list
   Def>        local p = ball.pos(b)
   Def>        local yy = comp.y(p)
   Def>        if yy >= y0 then
   Def>        if yy <= y1 then
   Def>            local rx = comp.x(p) - cx
   Def>            local rz = comp.z(p) - cz
   Def>            local rr = math.sqrt(rx*rx + rz*rz)
   Def>            if rr >= 1.35 then
   Def>            if rr <= 2.0 then
   Def>                local ang = math.atan2(rz, rx)/math.degrad
   Def>                if ang < 0.0 then
   Def>                    ang = 360.0 + ang
   Def>                end_if
   Def>                local d = ball.disp(b)
   Def>                local ri = -(comp.x(d)*rx/rr + comp.z(d)*rz/rr)
   Def>                local iscorner = 0
   Def>                if ang >= 250.0 then
   Def>                    if ang <= 320.0 then
   Def>                        iscorner = 1
   Def>                    end_if
   Def>                end_if
   Def>                if iscorner = 1 then
   Def>                    scorner = scorner + ri
   Def>                    nb_corner = nb_corner + 1
   Def>                    if ri > mx_corner then
   Def>                        mx_corner = ri
   Def>                    end_if
   Def>                else
   Def>                    sblue = sblue + ri
   Def>                    nb_blue = nb_blue + 1
   Def>                    if ri > mx_blue then
   Def>                        mx_blue = ri
   Def>                    end_if
   Def>                end_if
   Def>            end_if
   Def>            end_if
   Def>        end_if
   Def>        end_if
   Def>    end_loop
   Def>    if nb_blue > 0 then
   Def>        cv_blue = sblue/float(nb_blue)
   Def>    end_if
   Def>    if nb_corner > 0 then
   Def>        cv_corner = scorner/float(nb_corner)
   Def>    end_if
   Def>    io.out('MID-CONV '+pfx+' INNERWALL(r1.35-2) BLUELINE(sidewall+crown) n='+string(nb_blue)+' radial_inward mean='+string(cv_blue*1000.0)+'mm max='+string(mx_blue*1000.0)+'mm | fixed-corner n='+string(nb_corner)+' mean='+string(cv_corner*1000.0)+'mm max='+string(mx_corner*1000.0)+'mm')
   Def>end
