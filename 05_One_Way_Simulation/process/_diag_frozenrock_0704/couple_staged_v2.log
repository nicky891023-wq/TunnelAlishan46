   Def>        xdat(i)  = string.token(ln,1)
   Def>        ydat(i)  = string.token(ln,2)
   Def>        zdat(i)  = string.token(ln,3)
   Def>        uxdat(i) = string.token(ln,4)
   Def>        uydat(i) = string.token(ln,5)
   Def>        uzdat(i) = string.token(ln,6)
   Def>        st = file.read(arr,1)
   Def>    end_loop
   Def>    st = file.close
   Def>    io.out('   CS-read '+fname+' ndata='+string(ndata))
   Def>end
flac3d>
flac3d>; ---- store per-gp IDW targets in gp.extra(1..3) (radius 6 m, 1/d^2, nearest fallback) ----
flac3d>fish define set_targets(radius)
   Def>    loop foreach local g gp.list
   Def>        if gp.group(g,'drive') = 'driven' then
   Def>            local p = gp.pos(g)
   Def>            local x = comp.x(p)
   Def>            local y = comp.y(p)
   Def>            local z = comp.z(p)
   Def>            local sw = 0.0
   Def>            local sux = 0.0
   Def>            local suy = 0.0
   Def>            local suz = 0.0
   Def>            local dmin = 1e30
   Def>            local i = 1
   Def>            loop while i <= ndata
   Def>                local dx = x - xdat(i)
   Def>                local dy = y - ydat(i)
   Def>                local dz = z - zdat(i)
   Def>                local d2 = dx*dx + dy*dy + dz*dz
   Def>                if d2 <= radius*radius then
   Def>                    local w = 1.0/math.max(d2,1e-10)
   Def>                    sw = sw + w
   Def>                    sux = sux + uxdat(i)*w
   Def>                    suy = suy + uydat(i)*w
   Def>                    suz = suz + uzdat(i)*w
   Def>                end_if
   Def>                if d2 < dmin then
   Def>                    dmin = d2
   Def>                    global inear = i
   Def>                end_if
   Def>                i = i + 1
   Def>            end_loop
   Def>            if sw > 0.0 then
   Def>                gp.extra(g,1) = sux/sw
   Def>                gp.extra(g,2) = suy/sw
   Def>                gp.extra(g,3) = suz/sw
   Def>            else
   Def>                gp.extra(g,1) = uxdat(inear)
   Def>                gp.extra(g,2) = uydat(inear)
   Def>                gp.extra(g,3) = uzdat(inear)
   Def>            end_if
   Def>        end_if
   Def>    end_loop
   Def>end
flac3d>
flac3d>; ---- one ramp substep: vel = remaining_delta / (subs_left * NCYC * dt=1) ----
flac3d>fish define set_sub_vel(subs_left)
   Def>    loop foreach local g gp.list
   Def>        if gp.group(g,'drive') = 'driven' then
   Def>            local d = gp.disp(g)
   Def>            local den = float(subs_left)*float(NCYC)
   Def>            gp.vel(g) = vector((gp.extra(g,1)-comp.x(d))/den, (gp.extra(g,2)-comp.y(d))/den, (gp.extra(g,3)-comp.z(d))/den)
   Def>        end_if
   Def>    end_loop
   Def>end
flac3d>fish define hold_driven
   Def>    loop foreach local g gp.list
   Def>        if gp.group(g,'drive') = 'driven' then
   Def>            gp.vel(g) = vector(0.0,0.0,0.0)
   Def>        end_if
   Def>    end_loop
   Def>end
flac3d>fish define ball_dmax
   Def>    local dm = 0.0
   Def>    loop foreach local b ball.list
   Def>        local d = ball.disp(b)
   Def>        local m = math.sqrt(comp.x(d)^2+comp.y(d)^2+comp.z(d)^2)
   Def>        if m > dm then
   Def>            dm = m
   Def>        end_if
   Def>    end_loop
   Def>    ball_dmax = dm
   Def>end
flac3d>
flac3d>; ---- per-stage driver ----
flac3d>fish define cs_stage(stg, fname)
   Def>    read_drive(fname)
   Def>    set_targets(6.0)
   Def>    local isub = 0
   Def>    loop while isub < NSUB
   Def>        isub = isub + 1
   Def>        set_sub_vel(NSUB - isub + 1)
   Def>        command
   Def>            model cycle [NCYC]
   Def>            model calm
   Def>        endcommand
   Def>    end_loop
   Def>    hold_driven
   Def>    command
   Def>        model solve ratio-average 1e-4 or cycles 8000
   Def>    endcommand
   Def>    local pfx = 'cs_s'+string(stg)
   Def>    dump_cracks(pfx)
   Def>    qa_walls(pfx, stg)
   Def>    mid_wall_force(pfx, 870.0, 900.0)
   Def>    mid_convergence(pfx, 870.0, 900.0)
   Def>    crack_sectors(pfx)
   Def>    export_pmap(pfx+'_pmap.txt')
   Def>    export_cwall(pfx+'_cwall.txt')
   Def>    io.out('CS-CHK stg'+string(stg)+' cracks_t='+string(ncr_t)+' cracks_s='+string(ncr_s)+' ball_dmax='+string(ball_dmax))
   Def>end
