flac3d>; fracture_track_v3.fis -- crack DFN tracker for the coupled BPM (2026-07-06).
flac3d>;   v3 change (performance): REMOVES all fragment operations that crippled v2 on
flac3d>;   this 456k-ball / 2.27M-bond model:
flac3d>;     - track_init no longer does `fragment register ball-ball` (v2 line 102 was
flac3d>;       a ~28-min single-threaded startup on this model).
flac3d>;     - add_crack no longer calls `fragment compute` every 50 cracks (v2 lines
flac3d>;       52-58 recomputed connectivity over ALL 456k balls per 50 cracks -> each
flac3d>;       staged stage crawled).
flac3d>;   The fragment system was used ONLY to cosmetically re-sync crack DFN
flac3d>;   positions after large-strain ball motion. At the mm-scale motion here the
flac3d>;   creation position == current position to <1 mm, so this is dropped with no
flac3d>;   meaningful loss. The crack_tension / crack_shear DFNs are still created per
flac3d>;   bond break (fracture.create), so dump_cracks / crack_sectors work unchanged.
flac3d>; ============================================================================
flac3d>fish define add_crack(entries)
   Def>    local contact    = entries(1)
   Def>    local mode       = entries(2)    ; slot2 = failure mode {1=tension, 2=shear}
   Def>    local frac_pos   = contact.pos(contact)
   Def>    local norm       = contact.normal(contact)
   Def>    local dfn_label  = 'crack'
   Def>    local bp1 = contact.end1(contact)
   Def>    local bp2 = contact.end2(contact)
   Def>    local frac_size = math.min(ball.radius(bp1), ball.radius(bp2))
   Def>    local arg = array.create(5)
   Def>    arg(1) = 'disk'
   Def>    arg(2) = frac_pos
   Def>    arg(3) = frac_size
   Def>    arg(4) = math.dip.from.normal(norm)/math.degrad
   Def>    arg(5) = math.ddir.from.normal(norm)/math.degrad
   Def>    if arg(5) < 0.0
   Def>        arg(5) = 360.0+arg(5)
   Def>    end_if
   Def>    global crack_num
   Def>    crack_num = crack_num + 1
   Def>    if mode = 1 then
   Def>        dfn_label = dfn_label + '_tension'
   Def>    else if mode = 2 then
   Def>        dfn_label = dfn_label + '_shear'
   Def>    endif
   Def>    global dfn = dfn.find(dfn_label)
   Def>    if dfn = null then
   Def>        dfn = dfn.create(dfn_label)
   Def>    endif
   Def>    local fnew = fracture.create(dfn,arg)
   Def>    fracture.prop(fnew,'age')  = mech.time.total
   Def>    fracture.extra(fnew,1) = bp1
   Def>    fracture.extra(fnew,2) = bp2
   Def>    crack_accum += 1
   Def>end
