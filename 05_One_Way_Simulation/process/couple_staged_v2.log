flac3d>fish define mid_convergence(pfx, y0, y1)
   Def>    local cx = 1297.0
   Def>    local cz = 1747.5
   Def>    ; INNER-WALL (r 1.35-2.0m) radial convergence, split by region (Codex): blue-line load region
   Def>    ;   (ang NOT in 250-320deg = sidewalls+crown) vs fixed-corner band (ang 250-320 = artifact).
   Def>    global cv_blue = 0.0
   Def>    global mx_blue = 0.0
   Def>    global nb_blue = 0
   Def>    global cv_corner = 0.0
   Def>    global mx_corner = 0.0
   Def>    global nb_corner = 0
   Def>    local sblue = 0.0
   Def>    local scorner = 0.0
   Def>    loop foreach local b ball.list
   Def>        local p = ball.pos(b)
   Def>        local yy = comp.y(p)
   Def>        if yy >= y0 then
   Def>        if yy <= y1 then
   Def>            local rx = comp.x(p) - cx
   Def>            local rz = comp.z(p) - cz
   Def>            local rr = math.sqrt(rx*rx + rz*rz)
   Def>            if rr >= 1.35 then
   Def>            if rr <= 2.0 then
   Def>                local ang = math.atan2(rz, rx)/math.degrad
   Def>                if ang < 0.0 then
   Def>                    ang = 360.0 + ang
   Def>                end_if
   Def>                local d = ball.disp(b)
   Def>                local ri = -(comp.x(d)*rx/rr + comp.z(d)*rz/rr)
   Def>                local iscorner = 0
   Def>                if ang >= 250.0 then
   Def>                    if ang <= 320.0 then
   Def>                        iscorner = 1
   Def>                    end_if
   Def>                end_if
   Def>                if iscorner = 1 then
   Def>                    scorner = scorner + ri
   Def>                    nb_corner = nb_corner + 1
   Def>                    if ri > mx_corner then
   Def>                        mx_corner = ri
   Def>                    end_if
   Def>                else
   Def>                    sblue = sblue + ri
   Def>                    nb_blue = nb_blue + 1
   Def>                    if ri > mx_blue then
   Def>                        mx_blue = ri
   Def>                    end_if
   Def>                end_if
   Def>            end_if
   Def>            end_if
   Def>        end_if
   Def>        end_if
   Def>    end_loop
   Def>    if nb_blue > 0 then
   Def>        cv_blue = sblue/float(nb_blue)
   Def>    end_if
   Def>    if nb_corner > 0 then
   Def>        cv_corner = scorner/float(nb_corner)
   Def>    end_if
   Def>    io.out('MID-CONV '+pfx+' INNERWALL(r1.35-2) BLUELINE(sidewall+crown) n='+string(nb_blue)+' radial_inward mean='+string(cv_blue*1000.0)+'mm max='+string(mx_blue*1000.0)+'mm | fixed-corner n='+string(nb_corner)+' mean='+string(cv_corner*1000.0)+'mm max='+string(mx_corner*1000.0)+'mm')
   Def>end
